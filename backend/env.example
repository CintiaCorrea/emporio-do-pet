# =====================================================
# Empório do Pet - Backend Environment Variables
# =====================================================
# Renomeie este arquivo para .env e configure os valores
# =====================================================

# ===== Server =====
NODE_ENV=development
PORT=3001

# ===== Database (PostgreSQL) =====
# Para desenvolvimento local com Docker (compose padrão / dev):
# - docker-compose.yml / docker-compose.dev.yml -> Postgres em localhost:5433
DATABASE_URL="postgresql://emporio:emporio_2024@localhost:5433/emporio_db?schema=public"
DIRECT_URL="postgresql://emporio:emporio_2024@localhost:5433/emporio_db?schema=public"

# Para o compose isolado do Empório:
# - docker compose -f docker-compose.emporio.yml up -d -> Postgres em localhost:15432
# DATABASE_URL="postgresql://emporio:emporio_2024@localhost:15432/emporio_db?schema=public"
# DIRECT_URL="postgresql://emporio:emporio_2024@localhost:15432/emporio_db?schema=public"

# Para produção (exemplo com Supabase/Neon):
# DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"
# DIRECT_URL="postgresql://user:password@host:5432/database?schema=public"

# ===== Redis =====
# Opção 1: URL completa (Upstash/Fly.io - recomendado para produção)
# REDIS_URL=redis://default:password@fly-app-name-redis.upstash.io:6379

# Opção 2: Variáveis separadas (para desenvolvimento local)
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=
REDIS_DB=0
# REDIS_TLS=true  # Habilitar TLS para conexões seguras

# ===== JWT/Authentication =====
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Compatibilidade com NextAuth (mesmo secret)
NEXTAUTH_SECRET=your-nextauth-secret-change-in-production

# ===== Frontend =====
FRONTEND_URL=http://localhost:3000

# ===== Email (Nodemailer) =====
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=noreply@emporiodopet.com

# ===== Integrações AI (Opcionais) =====
# Chaves de API para provedores de IA
# O sistema usa estas chaves diretamente (single-tenant)
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=

# ===== WhatsApp Business API (Meta Cloud API) =====
# Obtenha em: https://developers.facebook.com/apps/
# Documentação: https://developers.facebook.com/docs/whatsapp/cloud-api
#
# IMPORTANTE: As credenciais podem ser configuradas de duas formas:
# 1. Variáveis de ambiente abaixo (para configuração global/sistema)
# 2. Pela UI em /dashboard/ai-agents/conexoes (salva no banco por usuário)
#
# O sistema prioriza as configurações por usuário do banco de dados.
# Use variáveis de ambiente apenas para valores padrão/fallback.
#
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_APP_SECRET=
# Token de verificação do webhook - deve ser o MESMO valor configurado no Meta
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_API_VERSION=v21.0

# ===== AI Service (FastAPI) =====
AI_SERVICE_URL=http://localhost:8000

# ===== WhatsApp AI Auto-Reply =====
# ID do agente AI padrão para auto-reply no WhatsApp
# Quando configurado, novas conversas serão automaticamente
# atribuídas a este agente com auto-reply habilitado
# Deixe em branco para desativar auto-reply automático
WHATSAPP_DEFAULT_AGENT_ID=

# ===== TTS Audio Cache =====
# Habilita/desabilita cache de áudio TTS no Redis (reduz custos e latência)
TTS_CACHE_ENABLED=true
# Tempo de vida do cache em segundos (padrão: 86400 = 24 horas)
TTS_CACHE_TTL=86400


# ===== Google Ads (painel de tráfego) =====
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_API_VERSION=v18
# Mapeamento segmento->conta (editável). Use os atalhos OU o JSON completo.
GOOGLE_ADS_ACCOUNT_CLINICA=
GOOGLE_ADS_ACCOUNT_FISIO=
GOOGLE_ADS_ACCOUNT_INTEGRATIVA=
GOOGLE_ADS_SEGMENTS=
GOOGLE_ADS_CPA_META=60

# --- Fase 4: conversões offline (Enhanced Conversions for Leads) ---
# IDs (só dígitos) das ações de conversão criadas no Google Ads, por conta.
# Deixe vazio para desligar o envio naquela conta.
GOOGLE_ADS_CONVERSION_ACTION_CLINICA=
GOOGLE_ADS_CONVERSION_ACTION_FISIO=
GOOGLE_ADS_CONVERSION_ACTION_INTEGRATIVA=
# Valor opcional por conversão (interno, em BRL). Vazio = só contagem.
GOOGLE_ADS_CONVERSION_VALUE=
