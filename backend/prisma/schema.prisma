// schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Enums //
enum Role {
  ADMIN
  VETERINARIAN
  RECEPTIONIST
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELED
  CONFIRMED
  IN_PROGRESS
}

// NOVO ENUM para status de pagamento
enum PaymentStatus {
  PAID
  PENDING
  OVERDUE
  CANCELLED
}

enum ProductType {
  MEDICINE
  VACCINE
  SERVICE
}

enum BoardType {
  APPOINTMENT
  TASK
  PROJECT
}

enum NewsletterStatus {
  DRAFT
  SCHEDULED
  SENT
  FAILED
}

enum RecipientType {
  CLIENT
  LEAD
  TUTOR
  ALL
}

enum FinanceEntryType {
  INCOME
  EXPENSE
}

enum FinanceEntryStatus {
  PAID
  PENDING
  OVERDUE
  CANCELED
}

enum FinancePaymentMethod {
  CASH
  PIX
  BOLETO
  CREDIT_CARD
  DEBIT_CARD
  TRANSFER
  OTHER
}

// NOVOS ENUMS para Tutor, Contact e Pet
enum PersonType {
  INDIVIDUAL
  LEGAL_ENTITY
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum ContactType {
  MOBILE
  PHONE
  BUSINESS
}

enum PetStatus {
  ACTIVE
  DECEASED
  TRANSFERRED
  INACTIVE
}

enum PetSpecies {
  CANINE
  FELINE
  BIRD
  RODENT
  REPTILE
  OTHER
}

enum SterilizationStatus {
  NOT_STERILIZED
  STERILIZED
  SCHEDULED
}

enum CoatType {
  SHORT
  LONG
  SMOOTH
  WAVY
  CURLY
  GOLDEN
  BLACK
  WHITE
  BROWN
  MIXED
}

// NextAuth Models
model Account {
  id                String   @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

// User Models - ATUALIZADO
model User {
  id            String       @id @default(uuid())
  name          String?
  email         String       @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role         @default(VETERINARIAN)
  permissions   String[]     @default([])
  isApproved    Boolean      @default(true)
  isBlocked     Boolean      @default(false)
  
  // Relacionamentos
  accounts      Account[]
  sessions      Session[]
  boards        Board[]
  newsletters   Newsletter[]
  appointments  Appointment[] // NOVO: Relacionamento com agendamentos
  financeEntries FinanceEntry[]
  integrationSettings IntegrationSettings?
  
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

// NOVOS MODELS: Tutor e Contact
model Tutor {
  id               String       @id @default(uuid())
  // Informações Básicas
  type             PersonType   @default(INDIVIDUAL)
  name             String
  email            String?      @unique
  nationality      String       @default("Brasileira")
  gender           Gender?
  // Documentos
  cpf              String?      @unique
  rg               String?
  birthDate        DateTime?    // Data completa para aniversário
  profession       String?
  // Como nos conheceu
  howFoundUs       String?
  // Preferências de Contato
  acceptsEmail     Boolean      @default(true)
  acceptsWhatsApp  Boolean      @default(true)
  acceptsSMS       Boolean      @default(true)
  acceptsSmsCampaign Boolean    @default(false)
  // Endereço
  cep              String?
  address          String?
  addressNumber    String?
  complement       String?
  referencePoint   String?
  neighborhood     String?
  city             String?
  state            String?
  // Extras
  observations     String?
  tags             String[]     // Para marcações
  formDate         DateTime?    // Ficha
  inclusionDate    DateTime?    // Inclusão
  // Contatos
  contacts         Contact[]
  // Relacionamentos
  recipients       Recipient[]
  pets             Pet[]
  appointments     Appointment[]
  // Timestamps
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@map("tutors")
}

model Contact {
  id           String      @id @default(uuid())
  type         ContactType @default(MOBILE)
  number       String
  isWhatsApp   Boolean     @default(false)
  observations String?
  isPrimary    Boolean     @default(false) // Para a estrela (favorito)
  tutorId      String
  tutor        Tutor       @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  // Timestamps
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@map("contacts")
}

// CRM Models
model Client {
  id          String       @id @default(uuid())
  name        String
  email       String       @unique
  phone       String?
  address     String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  // Manter apenas relacionamentos comerciais (vendas, newsletter)
  recipients  Recipient[]
}

// ATUALIZADO: Pet agora relaciona com Tutor e tem campos expandidos
model Pet {
  id              String            @id @default(uuid())
  name            String
  species         PetSpecies        @default(CANINE)
  breed           String?
  status          PetStatus         @default(ACTIVE)
  gender          Gender?
  sterilization   SterilizationStatus? @default(NOT_STERILIZED)
  birthDate       DateTime?
  coat            CoatType?
  coatColor       String?           // Cor específica da pelagem
  weight          Float?            // Peso do animal
  microchip       String?           // Número do microchip
  avatar          String?           // URL da foto do pet
  observations    String?           // Observações gerais
  allergies       String[]          // Lista de alergias
  medicalNotes    String?           // Notas médicas importantes
  // Relacionamentos
  tutorId         String
  tutor           Tutor             @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  appointments    Appointment[]
  treatments      Treatment[]
  // Timestamps
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@map("pets")
}

// ATUALIZADO: Appointment com campos para a UI
model Appointment {
  id           String            @id @default(uuid())
  tutorId      String
  petId        String
  userId       String            // Veterinário responsável
  date         DateTime
  duration     Int               @default(30) // Duração em minutos
  description  String?
  notes        String?
  value        Float             @default(0)
  status       String            @default("SCHEDULED")
  paymentStatus PaymentStatus    @default(PENDING)
  
  // Relacionamentos
  tutor        Tutor             @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  pet          Pet               @relation(fields: [petId], references: [id], onDelete: Cascade)
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  treatments   Treatment[]
  kanbanCard   KanbanCard?
  boardId      String?
  board        Board?   @relation(fields: [boardId], references: [id], onDelete: SetNull)
  
  // Timestamps
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([date])
  @@index([status])
  @@index([userId])
}

model Treatment {
  id            String      @id @default(uuid())
  appointmentId String
  petId         String
  description   String
  cost          Float
  productId     String?
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  pet           Pet         @relation(fields: [petId], references: [id], onDelete: Cascade)
  product       Product?    @relation(fields: [productId], references: [id], onDelete: SetNull)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Product {
  id          String      @id @default(uuid())
  name        String
  type        ProductType
  price       Float
  stock       Int         @default(0)
  treatments  Treatment[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

// Kanban Models
model Board {
  id          String        @id @default(uuid())
  name        String
  type        BoardType     @default(APPOINTMENT)
  description String?
  color       String        @default("bg-blue-500")
  progress    Int           @default(0)
  totalDeals  Int           @default(0)
  favorite    Boolean       @default(false)
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  columns     KanbanColumn[]
  appointments Appointment[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  @@unique([userId, name])
}

model KanbanColumn {
  id          String       @id @default(uuid())
  name        String
  position    Int
  color       String?
  boardId     String
  board       Board        @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards       KanbanCard[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  @@unique([boardId, name])
  @@unique([boardId, position])
}

model KanbanCard {
  id            String       @id @default(uuid())
  title         String
  description   String?
  position      Int
  columnId      String
  column        KanbanColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)
  appointmentId String?      @unique
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  metadata      Json?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  @@unique([columnId, position])
}

// Financeiro (ERP) - Lançamentos
model FinanceEntry {
  id               String             @id @default(uuid())
  userId           String
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  type             FinanceEntryType   @default(INCOME)
  status           FinanceEntryStatus @default(PENDING)
  method           FinancePaymentMethod? @default(OTHER)

  // Para manter a UI atual (Cliente / Serviço)
  counterpartyName String
  service          String
  description      String?

  // Armazenar em centavos para evitar problemas de float
  amountCents      Int

  date             DateTime           @default(now())
  dueDate          DateTime?
  paidAt           DateTime?

  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([userId, date])
  @@index([userId, status])
  @@index([userId, type])
}

// Newsletter Models - ATUALIZADO com NewsletterTemplate
model Newsletter {
  id            String         @id @default(uuid())
  title         String
  subject       String
  content       String
  status        NewsletterStatus
  scheduledFor  DateTime?
  recipientType RecipientType
  sentAt        DateTime?
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateId    String?        // NOVO: Referência ao template usado
  template      NewsletterTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  recipients    Recipient[]
  newsletterLogs NewsletterLog[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

// NOVO MODEL: NewsletterTemplate
model NewsletterTemplate {
  id          String       @id @default(uuid())
  name        String       @unique
  subject     String
  content     String       @db.Text
  description String?
  category    String       @default("Geral")
  isActive    Boolean      @default(true)
  
  // Relacionamentos
  newsletters Newsletter[]
  
  // Timestamps
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("newsletter_templates")
}

model Recipient {
  id           String     @id @default(uuid())
  newsletterId String
  clientId     String?
  tutorId      String?
  leadEmail    String?
  newsletter   Newsletter @relation(fields: [newsletterId], references: [id], onDelete: Cascade)
  client       Client?    @relation(fields: [clientId], references: [id], onDelete: SetNull)
  tutor        Tutor?     @relation(fields: [tutorId], references: [id], onDelete: SetNull)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  
  @@unique([newsletterId, clientId])
  @@unique([newsletterId, leadEmail])
  @@unique([newsletterId, tutorId])
}

model NewsletterLog {
  id           String     @id @default(uuid())
  newsletterId String
  sentAt       DateTime   @default(now())
  details      Json?
  newsletter   Newsletter @relation(fields: [newsletterId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  @@index([newsletterId])
  @@index([sentAt])
}

// Model para configurações de integrações
model IntegrationSettings {
  id              String   @id @default(uuid())
  userId          String   @unique
  
  // Configurações das integrações (armazenadas como JSON)
  whatsappConfig  String?  @db.Text
  openaiConfig    String?  @db.Text
  geminiConfig    String?  @db.Text
  deepseekConfig  String?  @db.Text
  
  // Relacionamento com usuário
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@map("integration_settings")
}

// ============================================
// CRM B2C - Leads com Insights Preditivos
// ============================================

enum LeadStatus {
  NEW
  ENRICHING
  ENRICHED
  QUALIFIED
  CONTACTED
  CONVERTED
  LOST
}

enum LeadSource {
  ORGANIC
  GOOGLE_ADS
  INSTAGRAM
  FACEBOOK
  TIKTOK
  REFERRAL
  LANDING_PAGE
  WHATSAPP
  EMAIL
  DIRECT
  OTHER
}

enum DeviceType {
  MOBILE
  DESKTOP
  TABLET
  UNKNOWN
}

enum InsightType {
  HIGH_INTENT
  REENGAGEMENT
  CHURN_RISK
  COLD_LEAD
  HOT_LEAD
  SEND_WHATSAPP
  SEND_EMAIL
  OFFER_DISCOUNT
  NURTURE_CONTENT
}

enum InsightPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Lead {
  id               String       @id @default(uuid())
  
  // Dados básicos
  name             String?
  email            String       @unique
  phone            String?
  
  // Origem e tracking
  source           LeadSource   @default(OTHER)
  sourceDetail     String?      // Ex: "campanha_verao_2024"
  utmSource        String?
  utmMedium        String?
  utmCampaign      String?
  utmContent       String?
  referrer         String?      // URL de referência
  landingPage      String?      // Página de entrada
  
  // Dispositivo e localização
  device           DeviceType   @default(UNKNOWN)
  userAgent        String?
  ip               String?      // Para geolocalização aproximada (não sensível)
  city             String?
  state            String?
  country          String       @default("BR")
  
  // Status e ciclo de vida
  status           LeadStatus   @default(NEW)
  firstSeenAt      DateTime     @default(now())
  lastSeenAt       DateTime     @default(now())
  lastActivityAt   DateTime?
  convertedAt      DateTime?
  
  // Score atual (desnormalizado para queries rápidas)
  currentScore     Int          @default(0)
  scoreUpdatedAt   DateTime?
  
  // Flags comportamentais (cache para queries)
  visitedPricing   Boolean      @default(false)
  abandonedCart    Boolean      @default(false)
  returnedWithin24h Boolean     @default(false)
  
  // Metadados extras
  tags             String[]     @default([])
  customFields     Json?        // Campos customizados
  notes            String?
  
  // Relacionamentos
  events           LeadEvent[]
  enrichment       LeadEnrichment?
  scores           LeadScore[]
  insights         LeadInsight[]
  history          LeadHistory[]
  
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  
  @@index([status])
  @@index([currentScore])
  @@index([source])
  @@index([lastSeenAt])
  @@index([email])
  @@map("leads")
}

model LeadEvent {
  id          String     @id @default(uuid())
  leadId      String
  lead        Lead       @relation(fields: [leadId], references: [id], onDelete: Cascade)
  
  // Tipo e dados do evento
  eventType   String     // page_view, pricing_view, checkout_start, checkout_abandon, form_submit, etc.
  eventData   Json?      // Dados extras do evento
  
  // Contexto
  page        String?    // URL ou identificador da página
  sessionId   String?    // Para agrupar eventos de uma sessão
  duration    Int?       // Tempo na página em segundos
  
  // Dispositivo (no momento do evento)
  device      DeviceType @default(UNKNOWN)
  
  createdAt   DateTime   @default(now())
  
  @@index([leadId, eventType])
  @@index([leadId, createdAt])
  @@index([sessionId])
  @@index([eventType])
  @@map("lead_events")
}

model LeadEnrichment {
  id              String   @id @default(uuid())
  leadId          String   @unique
  lead            Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  
  // Análise de email
  emailProvider   String?  // gmail, hotmail, outlook, corporativo, etc.
  emailValid      Boolean  @default(true)
  emailDisposable Boolean  @default(false)
  emailRisk       String?  // low, medium, high
  
  // Dados comportamentais agregados
  totalPageViews      Int     @default(0)
  uniquePages         Int     @default(0)
  pricingPageViews    Int     @default(0)
  checkoutStarts      Int     @default(0)
  checkoutAbandons    Int     @default(0)
  formSubmissions     Int     @default(0)
  totalSessions       Int     @default(0)
  avgSessionDuration  Int     @default(0)  // segundos
  totalTimeOnSite     Int     @default(0)  // segundos
  
  // Padrões temporais
  preferredTimeSlot   String? // morning, afternoon, evening, night
  preferredDayOfWeek  String? // monday, tuesday, etc.
  mostActiveHour      Int?    // 0-23
  
  // Engajamento
  daysActive          Int     @default(0)
  daysSinceFirstVisit Int     @default(0)
  daysSinceLastVisit  Int     @default(0)
  visitFrequency      Float   @default(0) // visitas por dia
  
  // Canal preferido (inferido)
  primaryChannel      String? // instagram, google, direto, etc.
  
  // Intenção de compra inferida
  purchaseIntent      String  @default("unknown") // low, medium, high, very_high
  
  // Raw data (para debug e reprocessamento)
  rawData             Json?
  
  enrichedAt          DateTime @default(now())
  version             Int      @default(1)
  
  @@index([emailDisposable])
  @@index([purchaseIntent])
  @@map("lead_enrichments")
}

model LeadScore {
  id          String   @id @default(uuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  
  // Score calculado
  score       Int      // 0-100
  
  // Breakdown explicável (auditoria)
  breakdown   Json     // { "pricing_view": 30, "email_valid": 10, "checkout_abandon": 20, ... }
  
  // Metadados
  version     Int      @default(1)
  algorithm   String   @default("rules_v1") // Para evolução futura para ML
  
  createdAt   DateTime @default(now())
  
  @@index([leadId, createdAt])
  @@index([score])
  @@map("lead_scores")
}

model LeadInsight {
  id          String          @id @default(uuid())
  leadId      String
  lead        Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)
  
  // Tipo e ação recomendada
  type        InsightType
  action      String          // "Abordar agora via WhatsApp", "Enviar email com desconto", etc.
  title       String          // Título curto para UI
  description String?         // Descrição detalhada
  
  // Prioridade e ordenação
  priority    InsightPriority @default(MEDIUM)
  confidence  Float           @default(0.8) // 0-1, confiança na recomendação
  
  // Rastreabilidade (quais regras/dados geraram)
  rule        String          // Nome da regra que gerou
  triggerData Json?           // Dados que triggaram o insight
  
  // Status
  dismissed   Boolean         @default(false)
  dismissedAt DateTime?
  actedOn     Boolean         @default(false)
  actedOnAt   DateTime?
  
  // Expiração (insights podem ficar obsoletos)
  expiresAt   DateTime?
  
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  
  @@index([leadId, dismissed])
  @@index([type])
  @@index([priority])
  @@index([expiresAt])
  @@map("lead_insights")
}

model LeadHistory {
  id          String   @id @default(uuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  
  // O que mudou
  action      String   // status_change, score_update, enrichment_complete, insight_generated, etc.
  field       String?  // Campo que mudou (se aplicável)
  oldValue    String?
  newValue    String?
  
  // Contexto
  metadata    Json?    // Dados extras sobre a mudança
  triggeredBy String?  // system, user, worker, etc.
  
  createdAt   DateTime @default(now())
  
  @@index([leadId, createdAt])
  @@index([action])
  @@map("lead_history")
}

