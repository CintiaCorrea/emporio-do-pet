// schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Enums //
enum Role {
  ADMIN
  VETERINARIAN
  RECEPTIONIST
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELED
  CONFIRMED
  IN_PROGRESS
  MISSED
}

enum AppointmentType {
  CONSULTA
  RETORNO
  AVALIACAO
  EMERGENCIA
  PROCEDIMENTO
  VACINACAO
  CIRURGIA
  SESSAO_FISIO
  OUTRO
}

// NOVO ENUM para status de pagamento
enum PaymentStatus {
  PAID
  PENDING
  OVERDUE
  CANCELLED
}

enum ProductType {
  MEDICINE
  VACCINE
  SERVICE
}

enum BoardType {
  APPOINTMENT
  CONSULTATION
  HOSPITALIZATION
  TREATMENT
  TASK
  PROJECT
  LEAD
  CLIENT
  SALES
}

enum NewsletterStatus {
  DRAFT
  SCHEDULED
  SENT
  FAILED
}

enum RecipientType {
  CLIENT
  LEAD
  TUTOR
  ALL
}

enum FinanceEntryType {
  INCOME
  EXPENSE
}

enum FinanceEntryStatus {
  PAID
  PENDING
  OVERDUE
  CANCELED
}

enum FinancePaymentMethod {
  CASH
  PIX
  BOLETO
  CREDIT_CARD
  DEBIT_CARD
  TRANSFER
  OTHER
}

// NOVOS ENUMS para Tutor, Contact e Pet
enum PersonType {
  INDIVIDUAL
  LEGAL_ENTITY
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum ContactType {
  MOBILE
  PHONE
  BUSINESS
}

enum PetStatus {
  ACTIVE
  DECEASED
  TRANSFERRED
  INACTIVE
}

enum PetSpecies {
  CANINE
  FELINE
  BIRD
  RODENT
  REPTILE
  OTHER
}

enum SterilizationStatus {
  NOT_STERILIZED
  STERILIZED
  SCHEDULED
}

enum CoatType {
  SHORT
  LONG
  SMOOTH
  WAVY
  CURLY
  GOLDEN
  BLACK
  WHITE
  BROWN
  MIXED
}

// Documentos (templates e documentos)
enum DocumentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum LandingPageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// Documentos Clínicos
enum ClinicalDocumentType {
  ANAMNESIS
  PRESCRIPTION
  DIAGNOSIS
  TUTOR_REPORT
  MEDICAL_CERTIFICATE
  EXAM_REQUEST
  SURGICAL_REPORT
  DISCHARGE_SUMMARY
  VACCINATION_CARD
  GENERAL
}

enum RecordingStatus {
  RECORDING
  PROCESSING
  TRANSCRIBED
  ANALYZED
  COMPLETED
  FAILED
}

// NextAuth Models
model Account {
  id                String   @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// User Models - ATUALIZADO
model User {
  id            String    @id @default(uuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(VETERINARIAN)
  permissions   String[]  @default([])
  isApproved    Boolean   @default(true)
  isBlocked     Boolean   @default(false)

  // Relacionamentos
  accounts            Account[]
  sessions            Session[]
  boards              Board[]
  newsletters         Newsletter[]
  appointments        Appointment[] // NOVO: Relacionamento com agendamentos
  appointmentItemsExecuted AppointmentItem[] @relation("AppointmentItemExecutor")
  financeEntries      FinanceEntry[]
  integrationSettings IntegrationSettings?
  profissional        Profissional?

  // AI Agents
  aiAgents       AIAgent[]
  agentTemplates AgentTemplate[]
  automations    Automation[]

  // WhatsApp
  whatsappConversations         WhatsAppConversation[]
  internalNotesSent             InternalNote[]         @relation("internal_notes_from")
  internalNotesReceived         InternalNote[]         @relation("internal_notes_to")
  interacoesRegistradas         Interacao[]            @relation("InteracaoAutor")
  whatsappConversationsTakeover WhatsAppConversation[] @relation("whatsapp_assigned_user")
  whatsappCampaigns             WhatsAppCampaign[]

  // Notificações
  notifications Notification[]

  // Documentos (templates)
  documents Document[]

  // Documentos Clínicos
  clinicalDocuments ClinicalDocument[]

  // Knowledge Bases (RAG)
  knowledgeBases KnowledgeBase[]

  // Landing Pages
  landingPages LandingPage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Document {
  id       String         @id @default(uuid())
  userId   String
  title    String
  content  String         @db.Text
  status   DocumentStatus @default(DRAFT)
  category String?
  tags     String[]       @default([])

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([category])
  @@map("documents")
}

// Landing Pages - Builder com export Elementor
model LandingPage {
  id          String            @id @default(uuid())
  userId      String
  name        String
  slug        String            @unique
  description String?
  content     Json              @default("{}")
  styles      Json?
  settings    Json?
  thumbnail   String?
  status      LandingPageStatus @default(DRAFT)
  publishedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([slug])
  @@map("landing_pages")
}

// NOVOS MODELS: Tutor e Contact
model Tutor {
  id                    String                 @id @default(uuid())
  // Pipeline & Follow-up (Inbox v3)
  estadoRelacionamento  String?  // Em dia / Pet em tratamento / Precisa de atenção / A recuperar / Inativo
  proximoFollowupAt     DateTime?
  resumoIa              String?  @db.Text
  resumoIaUpdatedAt     DateTime?
  interacoes            Interacao[]
  // Informações Básicas
  type                  PersonType             @default(INDIVIDUAL)
  name                  String
  isActive              Boolean                @default(true) @map("isactive")
  email                 String?                @unique
  nationality           String                 @default("Brasileira")
  gender                Gender?
  // Documentos
  cpf                   String?                @unique
  rg                    String?
  birthDate             DateTime? // Data completa para aniversário
  profession            String?
  // Como nos conheceu
  howFoundUs            String?
  // Preferências de Contato
  acceptsEmail          Boolean                @default(true)
  acceptsWhatsApp       Boolean                @default(true)
  acceptsSMS            Boolean                @default(true)
  acceptsSmsCampaign    Boolean                @default(false)
  // Endereço
  cep                   String?
  address               String?
  addressNumber         String?
  complement            String?
  referencePoint        String?
  neighborhood          String?
  city                  String?
  state                 String?
  // Extras
  observations          String?
  notaCliente           String? // 'Caixinha lembrar' — Cintia
  tags                  String[] // Para marcações
  formDate              DateTime? // Ficha
  inclusionDate         DateTime? // Inclusão
  // Status comercial (unificado de Client)
  status                TutorStatus            @default(ACTIVE)
  classificacao         TutorClassificacao     @default(Cliente)
  companyName           String?
  cnpj                  String?                @unique
  convertedFromLeadId   String?
  // Contatos
  contacts              Contact[]
  // Relacionamentos
  recipients            Recipient[]
  pets                  Pet[]
  appointments          Appointment[]
  clinicalDocuments     ClinicalDocument[]
  kanbanCards           KanbanCard[]
  // WhatsApp
  whatsappConversations WhatsAppConversation[]
  // Timestamps
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  @@map("tutors")
}

model Contact {
  id           String      @id @default(uuid())
  type         ContactType @default(MOBILE)
  number       String
  isWhatsApp   Boolean     @default(false)
  observations String?
  isPrimary    Boolean     @default(false) // Para a estrela (favorito)
  tutorId      String
  tutor        Tutor       @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  // Timestamps
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@map("contacts")
}

// (Client model removido — unificado em Tutor via classificacao)

enum TutorStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  CHURNED
}

enum TutorClassificacao {
  Cliente
  Fornecedor
  Parceiro
  Candidato_a_vaga
  Engano
  Indicacao_nao_cliente
  Ex_cliente
}


// ATUALIZADO: Pet agora relaciona com Tutor e tem campos expandidos
model Pet {
  id            String               @id @default(uuid())
  name          String
  species       PetSpecies           @default(CANINE)
  breed         String?
  status        PetStatus            @default(ACTIVE)
  gender        Gender?
  sterilization SterilizationStatus? @default(NOT_STERILIZED)
  birthDate     DateTime?
  coat          CoatType?
  coatColor     String? // Cor específica da pelagem
  weight        Float? // Peso do animal
  microchip     String? // Número do microchip
  avatar        String? // URL da foto do pet
  observations  String? // Observações gerais
  allergies     String[] // Lista de alergias
  medicalNotes  String? // Notas médicas importantes
  documents     String[]             @default([]) // Lista de documentos (URLs/nomes)
  // Pipeline & Follow-up (Inbox v3)
  pipelineClinicoEtapa String?  // Diagnóstico inicial / Em tratamento / Aguardando exames / Retorno agendado / Em manutenção / Alta clínica / Abandonou
  pipelineFisioEtapa   String?  // Avaliação inicial / Pacote em andamento / Sessão a sessão / Manutenção / Reavaliação / Alta / Pausa
  proximoFollowupAt    DateTime?
  interacoes           Interacao[]
  // Relacionamentos
  tutorId       String
  tutor         Tutor                @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  appointments  Appointment[]
  treatments    Treatment[]
  clinicalDocuments ClinicalDocument[]
  // Timestamps
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@map("pets")
}

// Raças de pet (por espécie) para autocomplete/criação dinâmica
model PetBreed {
  id        String     @id @default(uuid())
  species   PetSpecies
  name      String
  nameKey   String     @map("name_key") // lowercase/trim para unicidade
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([species, nameKey])
  @@index([species])
  @@map("pet_breeds")
}

// ATUALIZADO: Appointment com campos para a UI
model Appointment {
  id            String        @id @default(uuid())
  tutorId       String
  petId         String
  userId        String // Veterinário responsável
  date          DateTime
  duration      Int           @default(30) // Duração em minutos
  description   String?
  notes         String?
  value         Float         @default(0)
  status        String        @default("SCHEDULED")
  paymentStatus PaymentStatus @default(PENDING)

  // Campos clínicos (ficha de atendimento)
  type              AppointmentType @default(CONSULTA)
  chiefComplaint    String? // motivo_consulta — queixa principal
  anamnesis         String? // anamnese
  physicalExam      String? // exame físico
  diagnosis         String? // diagnostico
  conduct           String? // conduta / tratamento adotado
  prescription      String? // prescrição médica
  examsRequested    String? // exames solicitados
  followUpNotes     String? // acompanhamento_proximo_contato (recepção/cadência)
  nextReturnDate    DateTime? // proximo_retorno (date)
  petWeight         Float? // peso_pet (kg)
  temperature       Float? // temperatura (ºC)
  paymentMethod     String? // forma_pagamento livre

  // Relacionamentos
  tutor      Tutor       @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  pet        Pet         @relation(fields: [petId], references: [id], onDelete: Cascade)
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  treatments Treatment[]
  items      AppointmentItem[]
  kanbanCard KanbanCard?
  boardId    String?
  board      Board?      @relation(fields: [boardId], references: [id], onDelete: SetNull)

  // Gravação e documentos clínicos
  recording         ConsultationRecording?
  clinicalDocuments ClinicalDocument[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([status])
  @@index([userId])
}

model Treatment {
  id            String      @id @default(uuid())
  appointmentId String
  petId         String
  description   String
  cost          Float
  productId     String?
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  pet           Pet         @relation(fields: [petId], references: [id], onDelete: Cascade)
  product       Product?    @relation(fields: [productId], references: [id], onDelete: SetNull)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Product {
  id         String      @id @default(uuid())
  name       String
  type       ProductType
  price      Float
  stock      Int         @default(0)
  treatments Treatment[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

// ============================================
// Documentos Clínicos - Gravação e Geração por IA
// ============================================

// Gravação de Consulta - Áudio e transcrição
model ConsultationRecording {
  id              String          @id @default(uuid())
  appointmentId   String          @unique
  userId          String
  audioUrl        String?         // URL do áudio armazenado
  audioFileName   String?         // Nome do arquivo de áudio
  audioDuration   Int?            // Duração em segundos
  transcription   String?         @db.Text // Transcrição completa
  aiAnalysis      String?         @db.Text // Análise da IA (JSON estruturado)
  aiSummary       String?         @db.Text // Resumo gerado pela IA
  status          RecordingStatus @default(RECORDING)
  language        String          @default("pt-BR")
  errorMessage    String?         // Mensagem de erro se falhou

  // Relacionamentos
  appointment     Appointment     @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  clinicalDocuments ClinicalDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@map("consultation_recordings")
}

// Documento Clínico - Gerado por IA ou manualmente
model ClinicalDocument {
  id              String               @id @default(uuid())
  appointmentId   String
  petId           String
  tutorId         String
  userId          String               // Veterinário que gerou
  recordingId     String?              // Gravação de origem (opcional)
  type            ClinicalDocumentType @default(GENERAL)
  title           String
  content         String               @db.Text // Conteúdo em texto
  htmlContent     String?              @db.Text // Conteúdo formatado HTML
  pdfUrl          String?              // URL do PDF gerado
  status          DocumentStatus       @default(DRAFT)
  isAiGenerated   Boolean              @default(false) // Se foi gerado por IA
  aiModel         String?              // Modelo de IA usado
  aiPromptUsed    String?              @db.Text // Prompt utilizado

  // Compartilhamento
  sharedVia       String[]             @default([]) // ["whatsapp", "email"]
  sharedAt        DateTime?
  sharedTo        String?              // Telefone ou email do destinatário

  // Metadados
  metadata        Json?                // Dados extras (ex: medicamentos, dosagens)
  version         Int                  @default(1) // Versão do documento
  signedBy        String?              // Nome do veterinário que assinou
  crmv            String?              // CRMV do veterinário

  // Relacionamentos
  appointment     Appointment          @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  pet             Pet                  @relation(fields: [petId], references: [id], onDelete: Cascade)
  tutor           Tutor                @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  recording       ConsultationRecording? @relation(fields: [recordingId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([appointmentId])
  @@index([petId])
  @@index([tutorId])
  @@index([userId])
  @@index([type])
  @@index([status])
  @@map("clinical_documents")
}

// Kanban Models
model Board {
  id           String         @id @default(uuid())
  name         String
  type         BoardType      @default(TASK)
  description  String?
  color        String         @default("bg-blue-500")
  progress     Int            @default(0)
  totalDeals   Int            @default(0)
  favorite     Boolean        @default(false)
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  columns      KanbanColumn[]
  appointments Appointment[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@unique([userId, name])
}

model KanbanColumn {
  id        String       @id @default(uuid())
  name      String
  position  Int
  color     String?
  boardId   String
  board     Board        @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards     KanbanCard[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([boardId, name])
  @@unique([boardId, position])
}

model KanbanCard {
  id            String       @id @default(uuid())
  title         String
  description   String?
  position      Int
  columnId      String
  column        KanbanColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)
  
  // Entity links - only one should be set per card
  appointmentId String?      @unique
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  leadId        String?      @unique
  lead          Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)
  tutorId       String?      @unique
  tutor         Tutor?       @relation(fields: [tutorId], references: [id], onDelete: SetNull)
  
  // Card metadata
  metadata      Json?
  priority      String?      @default("medium") // low, medium, high, urgent
  dueDate       DateTime?
  assignedTo    String?      // User ID assigned to this card
  tags          String[]     @default([])
  
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([columnId, position])
  @@index([leadId])
  @@index([tutorId])
  @@map("kanban_cards")
}

// Financeiro (ERP) - Lançamentos
model FinanceEntry {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type   FinanceEntryType      @default(INCOME)
  status FinanceEntryStatus    @default(PENDING)
  method FinancePaymentMethod? @default(OTHER)

  // Para manter a UI atual (Cliente / Serviço)
  counterpartyName String
  service          String
  description      String?

  // Armazenar em centavos para evitar problemas de float
  amountCents Int

  date    DateTime  @default(now())
  dueDate DateTime?
  paidAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, date])
  @@index([userId, status])
  @@index([userId, type])
}

// Newsletter Models - ATUALIZADO com NewsletterTemplate
model Newsletter {
  id             String              @id @default(uuid())
  title          String
  subject        String
  content        String
  status         NewsletterStatus
  scheduledFor   DateTime?
  recipientType  RecipientType
  sentAt         DateTime?
  userId         String
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateId     String? // NOVO: Referência ao template usado
  template       NewsletterTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  recipients     Recipient[]
  newsletterLogs NewsletterLog[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
}

// NOVO MODEL: NewsletterTemplate
model NewsletterTemplate {
  id          String  @id @default(uuid())
  name        String  @unique
  subject     String
  content     String  @db.Text
  description String?
  category    String  @default("Geral")
  isActive    Boolean @default(true)

  // Relacionamentos
  newsletters Newsletter[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("newsletter_templates")
}

model Recipient {
  id           String     @id @default(uuid())
  newsletterId String
  tutorId      String?
  leadEmail    String?
  newsletter   Newsletter @relation(fields: [newsletterId], references: [id], onDelete: Cascade)
  tutor        Tutor?     @relation(fields: [tutorId], references: [id], onDelete: SetNull)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([newsletterId, leadEmail])
  @@unique([newsletterId, tutorId])
}

model NewsletterLog {
  id           String     @id @default(uuid())
  newsletterId String
  sentAt       DateTime   @default(now())
  details      Json?
  newsletter   Newsletter @relation(fields: [newsletterId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([newsletterId])
  @@index([sentAt])
}

// Model para configurações de integrações
model IntegrationSettings {
  id     String @id @default(uuid())
  userId String @unique

  // Configurações das integrações (armazenadas como JSON)
  whatsappConfig String? @db.Text
  openaiConfig   String? @db.Text
  geminiConfig   String? @db.Text
  deepseekConfig String? @db.Text
  emailConfig    String? @db.Text // SMTP config for sending emails

  // AI Usage limits per user
  aiMonthlyBudgetUsd   Float?  // Monthly budget limit in USD (null = unlimited)
  aiCurrentMonthCostUsd Float  @default(0) // Current month's spending
  aiLastResetAt        DateTime @default(now()) // Last budget reset date

  // CRM/Automation settings
  metadata Json?  // Additional settings (autoCreateLeadsFromWhatsApp, etc.)

  // Relacionamento com usuário
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("integration_settings")
}

// ============================================
// AI Agents - Agentes, Templates e Automações
// ============================================

enum AIProvider {
  OPENAI
  GEMINI
  DEEPSEEK
}

enum AgentType {
  CHATBOT
  AUTOMATION
  ASSISTANT
  SCHEDULER
}

enum AgentStatus {
  ACTIVE
  PAUSED
  DRAFT
  ERROR
}

enum TemplateCategory {
  ATENDIMENTO
  VENDAS
  MARKETING
  SUPORTE
  AGENDAMENTO
  PERSONALIZADO
}

enum TemplateStatus {
  PUBLISHED
  DRAFT
  ARCHIVED
}

enum AutomationCategory {
  ATENDIMENTO
  MARKETING
  NOTIFICACAO
  INTEGRACAO
  AGENDAMENTO
}

enum AutomationTrigger {
  SCHEDULE
  WEBHOOK
  EVENT
  MANUAL
  // CRM Triggers
  LEAD_CREATED
  LEAD_SCORE_CHANGED
  LEAD_STATUS_CHANGED
  LEAD_QUALIFIED
  LEAD_CONVERTED
  CLIENT_CREATED
  CLIENT_STATUS_CHANGED
  // WhatsApp Triggers  
  WHATSAPP_MESSAGE_RECEIVED
  WHATSAPP_CONVERSATION_STARTED
}

enum ExecutionStatus {
  SUCCESS
  FAILED
  PENDING
  RUNNING
}

// ============================================
// WhatsApp Business API - Mensagens e Conversas
// ============================================

enum WhatsAppMessageType {
  TEXT
  IMAGE
  DOCUMENT
  AUDIO
  VIDEO
  LOCATION
  TEMPLATE
  INTERACTIVE
  BUTTON
  STICKER
  CONTACTS
}

enum WhatsAppMessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

enum WhatsAppMessageDirection {
  INBOUND
  OUTBOUND
}

enum WhatsAppConversationStatus {
  OPEN
  CLOSED
  PENDING
  ASSIGNED
}

enum WhatsAppCampaignStatus {
  DRAFT
  SCHEDULED
  RUNNING
  COMPLETED
  FAILED
  PAUSED
}

// AI Agent - Agentes de IA configuráveis
model AIAgent {
  id           String      @id @default(uuid())
  userId       String
  name         String
  description  String?
  type         AgentType   @default(CHATBOT)
  status       AgentStatus @default(DRAFT)
  provider     AIProvider  @default(OPENAI)
  model        String      @default("gpt-4o-mini")
  systemPrompt String      @db.Text
  temperature  Float       @default(0.7)
  maxTokens    Int         @default(4096)
  templateId   String?

  // WhatsApp Template (from Meta API)
  whatsappTemplateId   String?  // Meta template ID (numeric string)
  whatsappTemplateName String?  // Template name for reference

  // WhatsApp Configuration
  whatsappEnabled          Boolean @default(false)
  whatsappAutoReply        Boolean @default(true)
  whatsappGreeting         String? @db.Text
  whatsappOfflineMessage   String? @db.Text
  whatsappBusinessHoursOnly Boolean @default(false)

  // CRM Configuration
  crmEnabled           Boolean @default(false)
  crmAutoCreateLead    Boolean @default(true)
  crmAutoUpdateLead    Boolean @default(true)
  crmLeadScoring       Boolean @default(false)
  crmNotifyOnHighScore Boolean @default(false)
  crmAssignToBoard     String? // Board ID for auto-assignment

  // RAG (Retrieval-Augmented Generation)
  knowledgeBaseId  String?
  knowledgeBase    KnowledgeBase? @relation(fields: [knowledgeBaseId], references: [id], onDelete: SetNull)
  knowledgeBaseIds String[]       @default([])
  ragEnabled       Boolean        @default(false)
  ragTopK          Int            @default(5)
  ragThreshold     Float          @default(0.7)

  // Configurações de voz (Text-to-Speech)
  voiceEnabled Boolean @default(false)
  voiceId      String  @default("nova") // alloy, echo, fable, onyx, nova, shimmer
  voiceSpeed   Float   @default(1.0)    // 0.25 to 4.0
  voiceModel   String  @default("tts-1") // tts-1 or tts-1-hd

  // Rate limiting
  rateLimitRequests Int @default(100)  // Max requests per window
  rateLimitWindow   Int @default(3600) // Window in seconds (1 hour default)

  // Cost tracking (accumulated)
  totalCostUsd Float @default(0)

  // Métricas (desnormalizadas para performance)
  totalInteractions Int       @default(0)
  successRate       Float     @default(0)
  avgResponseTime   Float     @default(0)
  lastActiveAt      DateTime?

  // Versionamento
  version       Int      @default(1)
  publishedAt   DateTime?

  // Relacionamentos
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  template    AgentTemplate?   @relation(fields: [templateId], references: [id], onDelete: SetNull)
  executions  AgentExecution[]
  automations Automation[]
  versions    AgentVersion[]

  // WhatsApp - conversas atribuídas a este agent
  whatsappConversations WhatsAppConversation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([type])
  @@map("ai_agents")
}

// Versão de Agente - Histórico de versões para rollback
model AgentVersion {
  id           String      @id @default(uuid())
  agentId      String
  version      Int
  name         String
  description  String?
  provider     AIProvider
  model        String
  systemPrompt String      @db.Text
  temperature  Float
  maxTokens    Int

  // Voice config snapshot
  voiceEnabled Boolean
  voiceId      String
  voiceSpeed   Float
  voiceModel   String

  // Metadata
  publishedBy  String?     // User ID who published
  changeNotes  String?     // Notes about this version

  // Relacionamentos
  agent AIAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([agentId, version])
  @@index([agentId, createdAt])
  @@map("agent_versions")
}

// Template de Agente - Prompts reutilizáveis
model AgentTemplate {
  id          String           @id @default(uuid())
  userId      String
  name        String
  description String?
  category    TemplateCategory @default(PERSONALIZADO)
  status      TemplateStatus   @default(DRAFT)
  content     String           @db.Text  // System prompt template
  variables   String[]         @default([])
  provider    AIProvider?
  model       String?
  isDefault   Boolean          @default(false)
  usageCount  Int              @default(0)
  rating      Float?

  // WhatsApp template integration (for templates approved by Meta)
  whatsappTemplateName     String?  // Nome do template no WhatsApp Business API
  whatsappTemplateLanguage String?  @default("pt_BR")
  whatsappTemplateId       String?  // ID do template na Meta
  isWhatsAppLinked         Boolean  @default(false)

  // Voice configuration defaults
  defaultVoiceEnabled Boolean @default(false)
  defaultVoiceId      String  @default("nova")
  defaultVoiceSpeed   Float   @default(1.0)
  defaultVoiceModel   String  @default("tts-1")

  // Relacionamentos
  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  agents AIAgent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, name])
  @@index([userId, category])
  @@index([status])
  @@index([whatsappTemplateName])
  @@map("agent_templates")
}

// Execução de Agente - Log de execuções
model AgentExecution {
  id        String          @id @default(uuid())
  agentId   String
  status    ExecutionStatus @default(PENDING)
  input     String?         @db.Text
  output    String?         @db.Text
  usage     Json? // {prompt_tokens, completion_tokens, total_tokens}
  latencyMs Int?
  error     String?         @db.Text
  metadata  Json? // Dados extras (tutor, pet, etc.)

  // Cost tracking
  costUsd       Float?  // Custo em USD da execução
  costBreakdown Json?   // {prompt_cost, completion_cost, total_cost, model, provider}

  // Voice response info
  voiceGenerated Boolean @default(false)
  voiceCostUsd   Float?  // Custo do TTS se usado

  // Relacionamentos
  agent AIAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([agentId, createdAt])
  @@index([status])
  @@map("agent_executions")
}

// Automação - Fluxos automatizados
model Automation {
  id            String             @id @default(uuid())
  userId        String
  agentId       String?
  name          String
  description   String?
  category      AutomationCategory @default(ATENDIMENTO)
  status        AgentStatus        @default(DRAFT)
  trigger       AutomationTrigger  @default(MANUAL)
  triggerConfig Json? // Configuração do trigger (cron, evento, etc.)

  // Métricas (desnormalizadas)
  executions  Int       @default(0)
  successRate Float     @default(0)
  avgDuration Float     @default(0)
  lastRunAt   DateTime?

  // Relacionamentos
  user  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent AIAgent?         @relation(fields: [agentId], references: [id], onDelete: SetNull)
  steps AutomationStep[]
  logs  AutomationLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([category])
  @@map("automations")
}

// Step de Automação - Passos do fluxo
model AutomationStep {
  id           String @id @default(uuid())
  automationId String
  type         String // query, filter, message, email, delay, webhook, ai_chat
  name         String
  config       Json? // Configuração específica do step
  position     Int

  // Relacionamentos
  automation Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([automationId, position])
  @@map("automation_steps")
}

// Log de Automação - Histórico de execuções
model AutomationLog {
  id            String          @id @default(uuid())
  automationId  String
  status        ExecutionStatus @default(PENDING)
  duration      Int? // ms
  triggeredBy   String? // manual, schedule, event, webhook
  stepsExecuted Int             @default(0)
  error         String?         @db.Text
  metadata      Json? // Dados extras da execução

  // Relacionamentos
  automation Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([automationId, createdAt])
  @@index([status])
  @@map("automation_logs")
}

// WhatsApp Message - Mensagens individuais
model WhatsAppMessage {
  id             String                   @id @default(uuid())
  conversationId String
  waMessageId    String?                  @unique // ID da mensagem no WhatsApp
  direction      WhatsAppMessageDirection @default(INBOUND)
  type           WhatsAppMessageType      @default(TEXT)
  status         WhatsAppMessageStatus    @default(PENDING)
  content        String                   @db.Text
  mediaUrl       String? // URL temporária do WhatsApp ou permanente do storage
  mediaType      String?
  mediaCaption   String?
  metadata       Json? // Dados extras (botões, template vars, etc)
  sentAt         DateTime?
  deliveredAt    DateTime?
  readAt         DateTime?
  failedReason   String?

  // Cloud storage - mídia permanente
  mediaCloudUrl     String? // URL permanente no cloud storage
  mediaCloudId      String? // ID público no cloud provider
  mediaStorageType  String? // local, s3, cloudinary, r2
  mediaDownloadedAt DateTime? // Quando a mídia foi baixada/armazenada

  // Relacionamentos
  conversation WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([conversationId, createdAt])
  @@index([waMessageId])
  @@index([status])
  @@index([direction])
  @@map("whatsapp_messages")
}

// WhatsApp Conversation - Conversas com contatos
model WhatsAppConversation {
  id                 String                     @id @default(uuid())
  userId             String
  contactPhone       String
  contactName        String?
  contactPushName    String? // Nome do push notification do WhatsApp
  status             WhatsAppConversationStatus @default(OPEN)
  assignedAgentId    String? // AI Agent atribuído para responder
  tutorId            String? // Tutor vinculado (se identificado)
  lastMessageAt      DateTime                   @default(now())
  lastMessagePreview String? // Preview da última mensagem
  unreadCount        Int                        @default(0)
  isAutoReplyEnabled Boolean                    @default(false)
  assignedUserId     String?
  humanTakeoverAt    DateTime?
  metadata           Json?

  // Relacionamentos
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedAgent AIAgent?          @relation(fields: [assignedAgentId], references: [id], onDelete: SetNull)
  assignedUser  User?             @relation("whatsapp_assigned_user", fields: [assignedUserId], references: [id], onDelete: SetNull)
  tutor         Tutor?            @relation(fields: [tutorId], references: [id], onDelete: SetNull)
  messages      WhatsAppMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, contactPhone])
  @@index([userId, status])
  @@index([userId, lastMessageAt])
  @@index([contactPhone])
  @@map("whatsapp_conversations")
}

// WhatsApp Campaign - Campanhas de envio em massa
model WhatsAppCampaign {
  id          String                 @id @default(uuid())
  userId      String
  name        String
  description String?
  status      WhatsAppCampaignStatus @default(DRAFT)

  // Template do WhatsApp Business API (se usar template aprovado)
  templateName     String?
  templateLanguage String? @default("pt_BR")

  // Conteúdo da mensagem
  messageContent String              @db.Text
  messageType    WhatsAppMessageType @default(TEXT)
  mediaUrl       String?

  // Filtro de audiência (JSON com critérios)
  audienceType   String @default("all") // all, tutors, leads, custom
  audienceFilter Json? // { status: 'ACTIVE', tags: ['vip'], etc }

  // Agendamento
  scheduledFor DateTime?
  startedAt    DateTime?
  completedAt  DateTime?

  // Métricas
  totalRecipients Int @default(0)
  sentCount       Int @default(0)
  deliveredCount  Int @default(0)
  readCount       Int @default(0)
  failedCount     Int @default(0)

  // Relacionamentos
  user       User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipients WhatsAppCampaignRecipient[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([scheduledFor])
  @@index([status])
  @@map("whatsapp_campaigns")
}

// WhatsApp Campaign Recipient - Destinatários de campanha
model WhatsAppCampaignRecipient {
  id           String                @id @default(uuid())
  campaignId   String
  phone        String
  name         String?
  tutorId      String?
  status       WhatsAppMessageStatus @default(PENDING)
  waMessageId  String? // ID da mensagem enviada
  sentAt       DateTime?
  deliveredAt  DateTime?
  readAt       DateTime?
  failedReason String?
  variables    Json? // Variáveis para template

  // Relacionamentos
  campaign WhatsAppCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([campaignId, phone])
  @@index([campaignId, status])
  @@index([phone])
  @@map("whatsapp_campaign_recipients")
}

// ============================================
// Notificações do Sistema (para step de automação)
// ============================================

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
  ALERT
  WHATSAPP_MESSAGE
  APPOINTMENT_REMINDER
  AUTOMATION_COMPLETE
  CAMPAIGN_COMPLETE
}

enum NotificationChannel {
  IN_APP
  EMAIL
  WHATSAPP
  PUSH
}

model Notification {
  id       String              @id @default(uuid())
  userId   String
  type     NotificationType    @default(INFO)
  channel  NotificationChannel @default(IN_APP)
  title    String
  message  String              @db.Text
  link     String? // Link para ação
  metadata Json? // Dados extras
  isRead   Boolean             @default(false)
  readAt   DateTime?

  // Relacionamentos
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([type])
  @@map("notifications")
}


// ============================================
// Mensagens agendadas (individuais — campanha existe à parte)
// ============================================
model WhatsAppScheduledMessage {
  id           String   @id @default(uuid())
  userId       String   // Quem agendou
  phone        String   // Destinatário (sem caracteres especiais)
  content      String   @db.Text
  scheduledFor DateTime
  status       String   @default("PENDING") // PENDING / SENT / FAILED / CANCELLED
  sentAt       DateTime?
  failedReason String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status, scheduledFor])
  @@index([userId])
  @@map("whatsapp_scheduled_messages")
}

// ============================================
// Notas internas entre membros da equipe
// ============================================
model InternalNote {
  id             String    @id @default(uuid())
  fromUserId     String
  toUserId       String
  content        String    @db.Text
  conversationId String?   // Opcional — se a nota refere a uma conversa do WhatsApp
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  fromUser User @relation("internal_notes_from", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("internal_notes_to", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([toUserId, readAt])
  @@index([conversationId])
  @@map("internal_notes")
}



// ============================================
// Profissional — membro da equipe (vet, recepção, etc)
// Separado de User: User é auth, Profissional é "membro da clínica"
// (pode ou não ter login no sistema)
// ============================================
model Profissional {
  id              String   @id @default(uuid())
  nomeCompleto    String   // Nome completo do profissional
  nomeExibicao    String?  // Nome usado em dropdowns (ex: "Dra. Vivian")
  iniciais        String?  // Iniciais pro avatar (máx 2 chars)
  tipo            ProfissionalTipo @default(VETERINARIO)
  especialidade   String?  // Ex: Fisioterapia, Medicina Integrativa
  crmv            String?  // CRMV ou outro registro
  telefone        String?
  email           String?  @unique
  fotoUrl         String?
  corAvatar       String?  // Cor hex usada quando sem foto
  comissaoPercentual Float? // % de comissão padrão
  userId          String?  @unique // Se tem login no sistema, vincula User
  dataInicio      DateTime? // Data de início
  observacoes     String?
  ativo           Boolean  @default(true)

  user      User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tipo])
  @@index([ativo])
  @@map("profissionais")
}

enum ProfissionalTipo {
  VETERINARIO
  RECEPCIONISTA
  ESTAGIARIO
  GERENTE
  OUTRO
}



// ============================================
// Etiquetas (tags) — categorias + templates aplicáveis a Lead/Cliente/Pet
// ============================================
model TagCategory {
  id        String   @id @default(uuid())
  nome      String
  ordem     Int      @default(0)
  ativo     Boolean  @default(true)
  etiquetas EtiquetaTemplate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ativo, ordem])
  @@map("tag_categories")
}

enum TipoEtiqueta {
  CLINICA
  STATUS
  CUSTOM
}

model EtiquetaTemplate {
  id         String       @id @default(uuid())
  texto      String       // Nome/texto da etiqueta
  tipo       TipoEtiqueta @default(CUSTOM)
  cor        String?      // Cor hex (#RRGGBB)
  descricao  String?
  aplicaEm   String[]     @default([]) // ["Lead","Cliente","Pet"]
  categoryId String?
  category   TagCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  ativo      Boolean      @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ativo, tipo])
  @@index([categoryId])
  @@map("etiqueta_templates")
}



// ============================================
// Serviços (catálogo de serviços e produtos vendidos pela clínica)
// ============================================
enum ComissaoBase {
  VALOR_CHEIO    // % sobre o preço
  MARGEM         // % sobre (valor - custo)
  SEM_COMISSAO   // não comissiona
  HERDAR         // usa o padrão da categoria (só faz sentido em Servico)
}

model ServiceCategory {
  id                    String        @id @default(uuid())
  nome                  String
  comissaoBasePadrao    ComissaoBase  @default(VALOR_CHEIO)
  ativo                 Boolean       @default(true)
  servicos              Servico[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ativo])
  @@map("service_categories")
}

model Servico {
  id                   String           @id @default(uuid())
  nome                 String
  appointmentItems     AppointmentItem[]
  valorPadrao          Float?           // R$
  custoPadrao          Float?           // R$ (medicamentos/vacinas/produtos)
  comissaoBaseDefault  ComissaoBase     @default(HERDAR)
  categoryId           String?
  category             ServiceCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  ativo                Boolean          @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ativo])
  @@index([categoryId])
  @@map("servicos")
}



// ============================================
// Raças (lista por espécie pra dropdowns de Pet)
// ============================================
enum EspecieRaca {
  CAO
  GATO
  OUTRO
}

model Raca {
  id      String      @id @default(uuid())
  nome    String
  especie EspecieRaca
  ordem   Int         @default(0)
  ativo   Boolean     @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([nome, especie])
  @@index([especie, ativo, ordem])
  @@map("racas")
}



// ============================================
// ListaTipo — registro de cada "lista" disponível no CRM
// (canais, origens, motivos_perda, status_clinico, etc)
// Permite admin criar listas novas além das padrão
// ============================================
model ListaTipo {
  id        String  @id @default(uuid())
  nome      String  @unique // identificador: "canais", "tipos_exame" etc
  label     String  // visível pro usuário: "Canais de entrada"
  emoji     String? // emoji decorativo
  descricao String?
  ordem     Int     @default(0)
  ativo     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ativo, ordem])
  @@map("lista_tipos")
}

// ============================================
// ListaItem — listas customizáveis (vocabulário do CRM)
// Ex: canais, origens, motivos_perda, status_clinico, etc
// ============================================
model ListaItem {
  id    String  @id @default(uuid())
  lista String  // identificador da lista (canais, origens, motivos_perda...)
  valor String  // valor visível pro usuário
  ordem Int     @default(0)
  ativo Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([lista, valor])
  @@index([lista, ativo, ordem])
  @@map("lista_itens")
}











// ============================================
// Config 10: Pipelines configuráveis
// Diferente dos pipelines fixos (Lead), aqui o admin define pipelines custom
// pra acompanhar outras coisas (vendas de pacotes, pós-venda, projetos internos)
// ============================================
enum PipelineEscopo {
  LEAD          // pipelines aplicáveis a Leads (substitui o LeadStatus enum estático)
  CLIENTE       // pipelines pra tutores/clientes (ex: jornada de fidelização)
  PROJETO       // pipelines de projetos internos
  CUSTOM
}

model PipelineDefinition {
  id          String           @id @default(uuid())
  nome        String
  escopo      PipelineEscopo   @default(CUSTOM)
  descricao   String?
  cor         String?          // hex pra destacar visualmente
  ativo       Boolean          @default(true)
  ordem       Int              @default(0)
  isPadrao    Boolean          @default(false)  // pipeline default pra esse escopo

  estagios    PipelineEstagio[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([escopo, ativo])
  @@map("pipeline_definitions")
}

model PipelineEstagio {
  id            String              @id @default(uuid())
  pipelineId    String
  pipeline      PipelineDefinition  @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  nome          String
  descricao     String?
  cor           String?             // hex pro chip do estágio
  ordem         Int
  ehInicial     Boolean             @default(false)  // primeiro estágio
  ehGanho       Boolean             @default(false)  // estágio de sucesso
  ehPerda       Boolean             @default(false)  // estágio de fracasso
  ativo         Boolean             @default(true)
  diasMaxParar  Int?                // SLA: alerta se passar X dias parado nesse estágio

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pipelineId, ordem])
  @@map("pipeline_estagios")
}

// ============================================
// Config 9: Templates de E-mail + Variáveis disponíveis
// Templates HTML/texto com placeholders + biblioteca de variáveis catalogadas
// ============================================
enum CategoriaEmail {
  TRANSACIONAL    // confirmação, agendamento, etc — operacional
  BOAS_VINDAS     // novos clientes
  EDUCATIVO       // newsletter, dicas
  PROMOCIONAL     // ofertas, pacotes
  ANIVERSARIO     // niver tutor/pet
  REENGAJAMENTO   // recuperação de inativos
  OUTRO
}

model EmailTemplate {
  id          String          @id @default(uuid())
  nome        String
  assunto     String          // assunto do email
  corpoHtml   String          // html template
  corpoTexto  String?         // versão texto plano (fallback)
  categoria   CategoriaEmail  @default(TRANSACIONAL)
  descricao   String?
  ativo       Boolean         @default(true)
  ordem       Int             @default(0)
  vezesEnviado Int            @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoria, ativo])
  @@map("email_templates")
}

model EmailVariable {
  id          String   @id @default(uuid())
  chave       String   @unique  // ex: tutor_nome, pet_nome
  label       String              // ex: "Nome do tutor"
  descricao   String?             // ex: "Primeiro nome do tutor responsável"
  exemplo     String?             // ex: "Cintia"
  categoria   String   @default("Geral")  // pra agrupar no seletor
  ordem       Int      @default(0)
  ativo       Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoria, ativo])
  @@map("email_variables")
}

// ============================================
// Config 8: Cadências — fluxos de mensagens automatizadas
// CadenciaTemplate (sequência) + CadenciaPasso (cada passo da sequência)
// ============================================
enum CadenciaGatilho {
  AGENDAMENTO_CRIADO
  AGENDAMENTO_CONFIRMADO
  ATENDIMENTO_FINALIZADO
  EXAME_SOLICITADO
  EXAME_PRONTO
  LEAD_NOVO
  LEAD_INATIVO_7D
  PACOTE_ATIVADO
  PACOTE_PROXIMO_DO_FIM
  NIVER_PET
  NIVER_TUTOR
  MANUAL
}

enum TipoPasso {
  WHATSAPP
  EMAIL
  TAREFA_INTERNA
  AGUARDAR
}

enum UnidadeTempo {
  MINUTOS
  HORAS
  DIAS
}

model CadenciaTemplate {
  id          String          @id @default(uuid())
  nome        String
  descricao   String?
  gatilho     CadenciaGatilho @default(MANUAL)
  ativo       Boolean         @default(true)
  ordem       Int             @default(0)

  passos      CadenciaPasso[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gatilho, ativo])
  @@map("cadencia_templates")
}

model CadenciaPasso {
  id          String       @id @default(uuid())
  cadenciaId  String
  cadencia    CadenciaTemplate @relation(fields: [cadenciaId], references: [id], onDelete: Cascade)
  ordem       Int
  tipo        TipoPasso    @default(WHATSAPP)
  titulo      String?      // nome curto pro passo (ex: "Lembrete 24h antes")
  conteudo    String       // texto da mensagem (com placeholders {tutor}, {pet})
  atrasoValor Int          @default(0)  // quanto tempo após o passo anterior
  atrasoUnidade UnidadeTempo @default(DIAS)
  ativo       Boolean      @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cadenciaId, ordem])
  @@map("cadencia_passos")
}

// ============================================
// Config 7: Scripts / Templates de Resposta
// Mensagens prontas pra recepção colar no WhatsApp
// ============================================
model ScriptCategory {
  id      String   @id @default(uuid())
  nome    String   @unique
  emoji   String?
  ordem   Int      @default(0)
  ativo   Boolean  @default(true)
  scripts ScriptTemplate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("script_categories")
}

model ScriptTemplate {
  id          String           @id @default(uuid())
  nome        String           // título curto, identificador
  conteudo    String           // texto com placeholders tipo {tutor}, {pet}, {data}
  descricao   String?          // contexto de uso
  variaveis   String[]         // lista de placeholders disponíveis
  categoryId  String?
  category    ScriptCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  ordem       Int              @default(0)
  ativo       Boolean          @default(true)
  vezesUsado  Int              @default(0) // contador de uso (analytics)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId, ativo])
  @@index([ativo, ordem])
  @@map("script_templates")
}

// ============================================
// Fornecedores (laboratórios, profissionais, parceiros)
// + Catálogo de exames terceirizados vinculados ao fornecedor
// ============================================
enum FornecedorTipo {
  LABORATORIO
  PROFISSIONAL
  PARCEIRO
  OUTRO
}

enum ModeloPagamento {
  LOTE_MENSAL          // pagamento em lote no fim do mês
  DIRETO_CLIENTE       // cliente paga direto pro fornecedor
  REPASSE_VIA_CLINICA  // clínica recebe e repassa
}

enum ComissaoTipo {
  PERCENTUAL
  VALOR_FIXO
  VARIAVEL
}

enum CategoriaExame {
  HEMATOLOGIA
  BIOQUIMICA
  IMAGEM
  CITOLOGIA
  MICROBIOLOGIA
  ENDOCRINOLOGIA
  HISTOPATOLOGIA
  OUTROS
}

model Fornecedor {
  id                   String           @id @default(uuid())
  nome                 String
  tipo                 FornecedorTipo   @default(LABORATORIO)
  especialidade        String?
  telefone             String?
  email                String?
  contatoResponsavel   String?
  modeloPagamento      ModeloPagamento  @default(LOTE_MENSAL)
  comissaoTipo         ComissaoTipo?
  comissaoValor        Float?
  diaFechamentoLote    Int?             // dia do mês (1-31)
  ativo                Boolean          @default(true)
  observacoes          String?

  exames CatalogoExame[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tipo, ativo])
