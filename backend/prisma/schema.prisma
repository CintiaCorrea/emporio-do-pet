  @@map("fornecedores")
}

model CatalogoExame {
  id                    String          @id @default(uuid())
  fornecedorId          String
  fornecedor            Fornecedor      @relation(fields: [fornecedorId], references: [id], onDelete: Cascade)
  codigo                String?
  nome                  String
  descricao             String?
  categoria             CategoriaExame  @default(OUTROS)
  valorFornecedor       Float?
  valorClienteSugerido  Float?
  tempoResultadoDias    Int?
  ativo                 Boolean         @default(true)
  observacoes           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fornecedorId, ativo])
  @@index([categoria, ativo])
  @@map("catalogo_exames")
}

// ============================================
// CRM B2C - Leads com Insights Preditivos
// ============================================


enum CommunicationChannel {
  WHATSAPP
  LIGACAO
  WALK_IN
  EMAIL
  OUTRO
}

enum LeadStatus {
  AGUARDANDO_TRIAGEM
  NEW
  ENRICHING
  ENRICHED
  QUALIFIED
  CONTACTED
  CONVERTED
  LOST
}

enum LeadSource {
  ORGANIC
  GOOGLE_ADS
  INSTAGRAM
  FACEBOOK
  TIKTOK
  REFERRAL
  LANDING_PAGE
  WHATSAPP
  EMAIL
  DIRECT
  OTHER
}

enum DeviceType {
  MOBILE
  DESKTOP
  TABLET
  UNKNOWN
}

enum InsightType {
  HIGH_INTENT
  REENGAGEMENT
  CHURN_RISK
  COLD_LEAD
  HOT_LEAD
  SEND_WHATSAPP
  SEND_EMAIL
  OFFER_DISCOUNT
  NURTURE_CONTENT
}

enum InsightPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Lead {
  id String @id @default(uuid())

  // Dados básicos
  name  String?
  email String  @unique
  phone String?

  // Origem e tracking
  source       LeadSource @default(OTHER)
  sourceDetail String? // Ex: "campanha_verao_2024"
  utmSource    String?
  utmMedium    String?
  utmCampaign  String?
  utmContent   String?
  referrer     String? // URL de referência
  landingPage  String? // Página de entrada

  // Dispositivo e localização
  device    DeviceType @default(UNKNOWN)
  userAgent String?
  ip        String? // Para geolocalização aproximada (não sensível)
  city      String?
  state     String?
  country   String     @default("BR")

  // Status e ciclo de vida
  status         LeadStatus @default(NEW)
  firstSeenAt    DateTime   @default(now())
  lastSeenAt     DateTime   @default(now())
  lastActivityAt DateTime?
  convertedAt    DateTime?
  // Pipeline & Follow-up (Inbox v3)
  pipelineComercialEtapa String?  // Triagem / Novo / Qualificação / Orçamento / Aguard retorno / Retomar / Reaproximação / Agendado / Compareceu / Perdido
  proximoFollowupAt      DateTime?
  resumoIa               String?  @db.Text
  resumoIaUpdatedAt      DateTime?
  interacoes             Interacao[]

  // Score atual (desnormalizado para queries rápidas)
  currentScore   Int       @default(0)
  scoreUpdatedAt DateTime?

  // Flags comportamentais (cache para queries)
  visitedPricing    Boolean @default(false)
  abandonedCart     Boolean @default(false)
  returnedWithin24h Boolean @default(false)

  // Metadados extras
  tags         String[] @default([])
  customFields Json? // Campos customizados
  notes        String?

  // Canal de comunicação preferencial
  channel      CommunicationChannel?

  // Qualificação (5 perguntas validadas no Base44)
  qualSituacaoPet      String?
  qualQueMaisIncomoda  String?
  qualTentouOutroVet   String?
  qualOQueMudaResolver String?
  qualQuemDecide       String?

  // Relacionamentos
  events     LeadEvent[]
  enrichment LeadEnrichment?
  scores     LeadScore[]
  insights   LeadInsight[]
  history    LeadHistory[]
  
  // CRM Integrations
  kanbanCards           KanbanCard[]
  convertedToTutorId    String?       // ID do Tutor se convertido
  whatsappConversationId String?      // Conversa que originou o lead

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([currentScore])
  @@index([source])
  @@index([lastSeenAt])
  @@index([email])
  @@index([convertedToTutorId])
  @@map("leads")
}

model LeadEvent {
  id     String @id @default(uuid())
  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  // Tipo e dados do evento
  eventType String // page_view, pricing_view, checkout_start, checkout_abandon, form_submit, etc.
  eventData Json? // Dados extras do evento

  // Contexto
  page      String? // URL ou identificador da página
  sessionId String? // Para agrupar eventos de uma sessão
  duration  Int? // Tempo na página em segundos

  // Dispositivo (no momento do evento)
  device DeviceType @default(UNKNOWN)

  createdAt DateTime @default(now())

  @@index([leadId, eventType])
  @@index([leadId, createdAt])
  @@index([sessionId])
  @@index([eventType])
  @@map("lead_events")
}

model LeadEnrichment {
  id     String @id @default(uuid())
  leadId String @unique
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  // Análise de email
  emailProvider   String? // gmail, hotmail, outlook, corporativo, etc.
  emailValid      Boolean @default(true)
  emailDisposable Boolean @default(false)
  emailRisk       String? // low, medium, high

  // Dados comportamentais agregados
  totalPageViews     Int @default(0)
  uniquePages        Int @default(0)
  pricingPageViews   Int @default(0)
  checkoutStarts     Int @default(0)
  checkoutAbandons   Int @default(0)
  formSubmissions    Int @default(0)
  totalSessions      Int @default(0)
  avgSessionDuration Int @default(0) // segundos
  totalTimeOnSite    Int @default(0) // segundos

  // Padrões temporais
  preferredTimeSlot  String? // morning, afternoon, evening, night
  preferredDayOfWeek String? // monday, tuesday, etc.
  mostActiveHour     Int? // 0-23

  // Engajamento
  daysActive          Int   @default(0)
  daysSinceFirstVisit Int   @default(0)
  daysSinceLastVisit  Int   @default(0)
  visitFrequency      Float @default(0) // visitas por dia

  // Canal preferido (inferido)
  primaryChannel String? // instagram, google, direto, etc.

  // Intenção de compra inferida
  purchaseIntent String @default("unknown") // low, medium, high, very_high

  // Raw data (para debug e reprocessamento)
  rawData Json?

  enrichedAt DateTime @default(now())
  version    Int      @default(1)

  @@index([emailDisposable])
  @@index([purchaseIntent])
  @@map("lead_enrichments")
}

model LeadScore {
  id     String @id @default(uuid())
  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  // Score calculado
  score Int // 0-100

  // Breakdown explicável (auditoria)
  breakdown Json // { "pricing_view": 30, "email_valid": 10, "checkout_abandon": 20, ... }

  // Metadados
  version   Int    @default(1)
  algorithm String @default("rules_v1") // Para evolução futura para ML

  createdAt DateTime @default(now())

  @@index([leadId, createdAt])
  @@index([score])
  @@map("lead_scores")
}

model LeadInsight {
  id     String @id @default(uuid())
  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  // Tipo e ação recomendada
  type        InsightType
  action      String // "Abordar agora via WhatsApp", "Enviar email com desconto", etc.
  title       String // Título curto para UI
  description String? // Descrição detalhada

  // Prioridade e ordenação
  priority   InsightPriority @default(MEDIUM)
  confidence Float           @default(0.8) // 0-1, confiança na recomendação

  // Rastreabilidade (quais regras/dados geraram)
  rule        String // Nome da regra que gerou
  triggerData Json? // Dados que triggaram o insight

  // Status
  dismissed   Boolean   @default(false)
  dismissedAt DateTime?
  actedOn     Boolean   @default(false)
  actedOnAt   DateTime?

  // Expiração (insights podem ficar obsoletos)
  expiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId, dismissed])
  @@index([type])
  @@index([priority])
  @@index([expiresAt])
  @@map("lead_insights")
}

model LeadHistory {
  id     String @id @default(uuid())
  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  // O que mudou
  action   String // status_change, score_update, enrichment_complete, insight_generated, etc.
  field    String? // Campo que mudou (se aplicável)
  oldValue String?
  newValue String?

  // Contexto
  metadata    Json? // Dados extras sobre a mudança
  triggeredBy String? // system, user, worker, etc.

  createdAt DateTime @default(now())

  @@index([leadId, createdAt])
  @@index([action])
  @@map("lead_history")
}

// ============================================
// Webhook Events - Para replay de webhooks falhos
// ============================================

model WebhookEvent {
  id        String  @id @default(uuid())
  userId    String
  eventType String // whatsapp_message, whatsapp_status, etc.
  payload   Json // Payload completo do webhook
  signature String? // Signature para validação

  // Status do processamento
  status       String    @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED, DEAD_LETTER
  attempts     Int       @default(0)
  lastError    String?   @db.Text
  nextRetryAt  DateTime?
  processedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([status, nextRetryAt])
  @@index([eventType])
  @@map("webhook_events")
}

// ============================================
// Knowledge Base - RAG (Retrieval-Augmented Generation)
// ============================================

model KnowledgeBase {
  id             String              @id @default(uuid())
  userId         String
  name           String
  description    String?
  status         String              @default("PROCESSING")
  totalDocuments Int                 @default(0)
  totalChunks    Int                 @default(0)
  totalSizeBytes Int                 @default(0)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents KnowledgeDocument[]
  agents    AIAgent[]

  @@index([userId])
  @@map("knowledge_bases")
}

model KnowledgeDocument {
  id              String @id @default(uuid())
  knowledgeBaseId String
  fileName        String
  fileType        String
  fileSize        Int
  filePath        String
  status          String @default("PENDING")
  chunkCount      Int    @default(0)
  errorMessage    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  knowledgeBase KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  chunks        DocumentChunk[]

  @@index([knowledgeBaseId])
  @@index([status])
  @@map("knowledge_documents")
}

model DocumentChunk {
  id         String                         @id @default(uuid())
  documentId String
  content    String                         @db.Text
  metadata   Json?
  chunkIndex Int
  tokenCount Int                            @default(0)
  embedding  Unsupported("vector(1536)")?
  createdAt  DateTime                       @default(now())

  document KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("document_chunks")
}

// ============================================
// Media Storage - Armazenamento permanente de mídia
// ============================================

model MediaFile {
  id        String @id @default(uuid())
  userId    String

  // Informações do arquivo
  originalFilename String
  mimeType         String
  size             Int // bytes
  
  // URLs
  localPath String? // Caminho local (se armazenado localmente)
  cloudUrl  String? // URL na nuvem (S3/Cloudinary)
  publicId  String? // ID público no provedor de cloud

  // Provedor
  storageProvider String @default("local") // local, s3, cloudinary, r2

  // Contexto de uso
  source    String? // whatsapp, upload, ai_generated, etc.
  sourceId  String? // ID da mensagem/entidade que originou

  // Metadados
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([source, sourceId])
  @@index([storageProvider])
  @@map("media_files")
}

// ============================================
// Config 11: Campanhas (marketing)
// ============================================
enum PlataformaCampanha {
  GOOGLE_ADS
  META_ADS_FACEBOOK
  META_ADS_INSTAGRAM
  TIKTOK_ADS
  OUTRAS
}
enum TipoCampanha {
  CONVERSAO
  TRAFEGO
  ENGAJAMENTO
  MENSAGEM_WHATSAPP
  RECONHECIMENTO
}
enum StatusCampanha {
  ATIVA
  PAUSADA
  ENCERRADA
  EM_TESTE
  PLANEJADA
}

model Campanha {
  id           String              @id @default(uuid())
  nome         String
  plataforma   PlataformaCampanha  @default(OUTRAS)
  tipo         TipoCampanha        @default(CONVERSAO)
  tagOrigem    String?             // tag pro BotConversa rastrear
  inicio       DateTime?           @db.Date
  fim          DateTime?           @db.Date
  status       StatusCampanha      @default(ATIVA)
  investimento Float?              // R$ total
  observacoes  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, plataforma])
  @@map("campanhas")
}

// ============================================
// Config 12: Metas
// ============================================
enum TipoMeta {
  FATURAMENTO_GERAL
  FATURAMENTO_INDIVIDUAL
  ATENDIMENTOS
  SERVICO_ESPECIFICO
  CONVERSOES
  NPS
}
enum PeriodicidadeMeta {
  SEMANAL
  MENSAL
  TRIMESTRAL
  SEMESTRAL
  ANUAL
}
enum StatusMeta {
  EM_ANDAMENTO
  ATINGIDA
  NAO_ATINGIDA
}

model Meta {
  id             String             @id @default(uuid())
  tipo           TipoMeta
  periodicidade  PeriodicidadeMeta  @default(MENSAL)
  profissionalId String?            // quando individual
  servicoId      String?            // quando serviço específico
  dataInicio     DateTime           @db.Date
  valorMeta      Float
  valorRealizado Float              @default(0)
  status         StatusMeta         @default(EM_ANDAMENTO)
  observacoes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tipo, status])
  @@index([dataInicio])
  @@map("metas")
}

// ============================================
// Config 13: Avaliações (NPS + Google Reviews)
// ============================================
enum CategoriaAlvoNPS {
  VET
  RECEPCAO
  CLINICA_GERAL
}
enum ClassificacaoNPS {
  PROMOTOR
  NEUTRO
  DETRATOR
}
enum CanalColetaNPS {
  PRESENCIAL
  WHATSAPP
  EMAIL
  TELEFONE
  FORMULARIO
}
enum StatusAvaliacaoGoogle {
  PERGUNTA_ENVIADA
  NAO_GOSTOU
  LINK_ENVIADO
  VOTOU
  NAO_VOTOU
  CANCELADO
}

model AvaliacaoNPS {
  id              String              @id @default(uuid())
  tutorId         String?
  petId           String?
  atendimentoId   String?
  categoriaAlvo   CategoriaAlvoNPS
  profissionalId  String?
  score           Int                 // 0-10
  classificacao   ClassificacaoNPS
  comentario      String?
  canalColeta     CanalColetaNPS      @default(PRESENCIAL)
  dataColeta      DateTime            @default(now())
  coletadoPor     String?             // email
  observacoes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dataColeta])
  @@index([classificacao])
  @@map("avaliacoes_nps")
}

model AvaliacaoGoogle {
  id              String                  @id @default(uuid())
  tutorId         String?
  petId           String?
  atendimentoId   String?
  profissionalId  String?
  coletadoPor     String?
  dataPergunta    DateTime                @default(now())
  gostou          Boolean?                // null = ainda não respondeu
  comentarioNegativo String?              // quando gostou=false
  canalEnvio      String?                 // WhatsApp, Email, SMS, etc
  dataEnvioLink   DateTime?
  linkEnviado     String?
  dataVoto        DateTime?
  notaDada        Int?                    // 1-5
  votoConfirmado  Boolean                 @default(false)
  status          StatusAvaliacaoGoogle   @default(PERGUNTA_ENVIADA)
  observacoes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([dataPergunta])
  @@map("avaliacoes_google")
}



// ============================================
// AppointmentItem — linhas de cobrança do atendimento
// (de onde sai vendas + comissões + lançamento financeiro)
// ============================================
model AppointmentItem {
  id              String       @id @default(uuid())
  appointmentId   String
  appointment     Appointment  @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  // Vinculação a catálogo (opcional — pode ser descrição livre)
  servicoId       String?
  servico         Servico?     @relation(fields: [servicoId], references: [id], onDelete: SetNull)
  descricao       String?

  // Executor: profissional interno OU fornecedor externo (lab)
  executorUserId  String?
  executorUser    User?        @relation("AppointmentItemExecutor", fields: [executorUserId], references: [id], onDelete: SetNull)
  fornecedorId    String?
  fornecedor      Fornecedor?  @relation("AppointmentItemFornecedor", fields: [fornecedorId], references: [id], onDelete: SetNull)

  // Valores
  quantidade      Float        @default(1)
  valorUnitario   Float        @default(0)
  custoUnitario   Float        @default(0)
  desconto        Float        @default(0)
  valorTotal      Float        @default(0)

  // Comissão
  comissaoBase    String?      // CHEIO | MARGEM | SEM
  comissaoTipo    String?      // PERCENTUAL | VALOR_FIXO
  comissaoValor   Float?
  comissaoCalculada Float?

  observacoes     String?

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([appointmentId])
  @@index([servicoId])
  @@index([fornecedorId])
  @@map("appointment_items")
}


// ============================================
// Interacao — registros de interação com Lead/Tutor/Pet
// (entra na ficha como histórico de FU)
// ============================================
model Interacao {
  id String @id @default(uuid())

  // Pode vincular a qualquer combinação
  leadId  String?
  lead    Lead?   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tutorId String?
  tutor   Tutor?  @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  petId   String?
  pet     Pet?    @relation(fields: [petId], references: [id], onDelete: SetNull)

  autorUserId String?
  autor       User?   @relation("InteracaoAutor", fields: [autorUserId], references: [id], onDelete: SetNull)

  tipo               String   @default("NOTA")  // NOTA | ENCAMINHAMENTO | AGENDAMENTO | EMAIL_ENVIADO | WHATSAPP_ENVIADO | LIGACAO | PRESENCIAL | PERDIDO
  texto              String   @db.Text
  proximaAcao        String?
  proximoFollowupAt  DateTime?
  canal              String?  // WhatsApp BC | WhatsApp Meta | Email | Ligação | Presencial

  threadId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
  @@index([tutorId])
  @@index([petId])
  @@index([createdAt])
  @@map("interacoes")
}
