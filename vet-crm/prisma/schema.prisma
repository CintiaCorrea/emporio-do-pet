// schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  relationMode = "prisma" 
}

// Enums //
enum Role {
  ADMIN
  VETERINARIAN
  RECEPTIONIST
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELED
  CONFIRMED
  IN_PROGRESS
}

// NOVO ENUM para status de pagamento
enum PaymentStatus {
  PAID
  PENDING
  OVERDUE
  CANCELLED
}

enum ProductType {
  MEDICINE
  VACCINE
  SERVICE
}

enum BoardType {
  APPOINTMENT
  TASK
  PROJECT
}

enum NewsletterStatus {
  DRAFT
  SCHEDULED
  SENT
  FAILED
}

enum RecipientType {
  CLIENT
  LEAD
  TUTOR
  ALL
}

// NOVOS ENUMS para Tutor, Contact e Pet
enum PersonType {
  INDIVIDUAL
  LEGAL_ENTITY
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum ContactType {
  MOBILE
  PHONE
  BUSINESS
}

enum PetStatus {
  ACTIVE
  DECEASED
  TRANSFERRED
  INACTIVE
}

enum PetSpecies {
  CANINE
  FELINE
  BIRD
  RODENT
  REPTILE
  OTHER
}

enum SterilizationStatus {
  NOT_STERILIZED
  STERILIZED
  SCHEDULED
}

enum CoatType {
  SHORT
  LONG
  SMOOTH
  WAVY
  CURLY
  GOLDEN
  BLACK
  WHITE
  BROWN
  MIXED
}

// NextAuth Models
model Account {
  id                String   @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

// User Models - ATUALIZADO
model User {
  id            String       @id @default(uuid())
  name          String?
  email         String       @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role         @default(VETERINARIAN)
  permissions   String[]     @default([])
  isApproved    Boolean      @default(true)
  isBlocked     Boolean      @default(false)
  
  // Relacionamentos
  accounts      Account[]
  sessions      Session[]
  boards        Board[]
  newsletters   Newsletter[]
  appointments  Appointment[] // NOVO: Relacionamento com agendamentos
  integrationSettings IntegrationSettings?
  documents     Document[]
  
  // AI Agents
  aiAgents        AIAgent[]
  agentTemplates  AgentTemplate[]
  automations     Automation[]
  
  // WhatsApp
  whatsappConversations WhatsAppConversation[]
  whatsappCampaigns     WhatsAppCampaign[]
  notifications         Notification[]

  // Documentos Clínicos
  clinicalDocuments ClinicalDocument[]
  
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

// NOVOS MODELS: Tutor e Contact
model Tutor {
  id               String       @id @default(uuid())
  // Informações Básicas
  type             PersonType   @default(INDIVIDUAL)
  name             String
  isActive         Boolean      @default(true) @map("isactive")
  email            String?      @unique
  nationality      String       @default("Brasileira")
  gender           Gender?
  // Documentos
  cpf              String?      @unique
  rg               String?
  birthDate        DateTime?    // Data completa para aniversário
  profession       String?
  // Como nos conheceu
  howFoundUs       String?
  // Preferências de Contato
  acceptsEmail     Boolean      @default(true)
  acceptsWhatsApp  Boolean      @default(true)
  acceptsSMS       Boolean      @default(true)
  acceptsSmsCampaign Boolean    @default(false)
  // Endereço
  cep              String?
  address          String?
  addressNumber    String?
  complement       String?
  referencePoint   String?
  neighborhood     String?
  city             String?
  state            String?
  // Extras
  observations     String?
  tags             String[]     // Para marcações
  formDate         DateTime?    // Ficha
  inclusionDate    DateTime?    // Inclusão
  // Contatos
  contacts         Contact[]
  // Relacionamentos
  recipients       Recipient[]
  pets             Pet[]
  appointments     Appointment[]
  clinicalDocuments ClinicalDocument[]
  // WhatsApp
  whatsappConversations WhatsAppConversation[]
  // Timestamps
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@map("tutors")
}

model Contact {
  id           String      @id @default(uuid())
  type         ContactType @default(MOBILE)
  number       String
  isWhatsApp   Boolean     @default(false)
  observations String?
  isPrimary    Boolean     @default(false) // Para a estrela (favorito)
  tutorId      String
  tutor        Tutor       @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  // Timestamps
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@map("contacts")
}

// CRM Models
model Client {
  id          String       @id @default(uuid())
  name        String
  email       String       @unique
  phone       String?
  address     String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  // Manter apenas relacionamentos comerciais (vendas, newsletter)
  recipients  Recipient[]
}

// ATUALIZADO: Pet agora relaciona com Tutor e tem campos expandidos
model Pet {
  id              String            @id @default(uuid())
  name            String
  species         PetSpecies        @default(CANINE)
  breed           String?
  status          PetStatus         @default(ACTIVE)
  gender          Gender?
  sterilization   SterilizationStatus? @default(NOT_STERILIZED)
  birthDate       DateTime?
  coat            CoatType?
  coatColor       String?           // Cor específica da pelagem
  weight          Float?            // Peso do animal
  microchip       String?           // Número do microchip
  avatar          String?           // URL da foto do pet
  observations    String?           // Observações gerais
  allergies       String[]          // Lista de alergias
  medicalNotes    String?           // Notas médicas importantes
  documents       String[]          @default([]) // Lista de documentos (URLs/nomes)
  // Relacionamentos
  tutorId         String
  tutor           Tutor             @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  appointments    Appointment[]
  treatments      Treatment[]
  clinicalDocuments ClinicalDocument[]
  // Timestamps
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@map("pets")
}

// Raças de pet (por espécie) para autocomplete/criação dinâmica
model PetBreed {
  id        String     @id @default(uuid())
  species   PetSpecies
  name      String
  nameKey   String     @map("name_key") // lowercase/trim para unicidade
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([species, nameKey])
  @@index([species])
  @@map("pet_breeds")
}

// ATUALIZADO: Appointment com campos para a UI
model Appointment {
  id           String            @id @default(uuid())
  tutorId      String
  petId        String
  userId       String            // Veterinário responsável
  date         DateTime
  duration     Int               @default(30) // Duração em minutos
  description  String?
  notes        String?
  value        Float             @default(0)
  status       String            @default("SCHEDULED")
  paymentStatus PaymentStatus    @default(PENDING)
  
  // Relacionamentos
  tutor        Tutor             @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  pet          Pet               @relation(fields: [petId], references: [id], onDelete: Cascade)
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  treatments   Treatment[]
  kanbanCard   KanbanCard?
  boardId      String?
  board        Board?   @relation(fields: [boardId], references: [id], onDelete: SetNull)

  // Gravação e documentos clínicos
  recording         ConsultationRecording?
  clinicalDocuments ClinicalDocument[]
  
  // Timestamps
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([date])
  @@index([status])
  @@index([userId])
}

model Treatment {
  id            String      @id @default(uuid())
  appointmentId String
  petId         String
  description   String
  cost          Float
  productId     String?
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  pet           Pet         @relation(fields: [petId], references: [id], onDelete: Cascade)
  product       Product?    @relation(fields: [productId], references: [id], onDelete: SetNull)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Product {
  id          String      @id @default(uuid())
  name        String
  type        ProductType
  price       Float
  stock       Int         @default(0)
  treatments  Treatment[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

// Kanban Models
model Board {
  id          String        @id @default(uuid())
  name        String
  type        BoardType     @default(APPOINTMENT)
  description String?
  color       String        @default("bg-blue-500")
  progress    Int           @default(0)
  totalDeals  Int           @default(0)
  favorite    Boolean       @default(false)
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  columns     KanbanColumn[]
  appointments Appointment[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  @@unique([userId, name])
}

model KanbanColumn {
  id          String       @id @default(uuid())
  name        String
  position    Int
  color       String?
  boardId     String
  board       Board        @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards       KanbanCard[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  @@unique([boardId, name])
  @@unique([boardId, position])
}

model KanbanCard {
  id            String       @id @default(uuid())
  title         String
  description   String?
  position      Int
  columnId      String
  column        KanbanColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)
  appointmentId String?      @unique
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  metadata      Json?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  @@unique([columnId, position])
}

// Newsletter Models - ATUALIZADO com NewsletterTemplate
model Newsletter {
  id            String         @id @default(uuid())
  title         String
  subject       String
  content       String
  status        NewsletterStatus
  scheduledFor  DateTime?
  recipientType RecipientType
  sentAt        DateTime?
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateId    String?        // NOVO: Referência ao template usado
  template      NewsletterTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  recipients    Recipient[]
  newsletterLogs NewsletterLog[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

// NOVO MODEL: NewsletterTemplate
model NewsletterTemplate {
  id          String       @id @default(uuid())
  name        String       @unique
  subject     String
  content     String       @db.Text
  description String?
  category    String       @default("Geral")
  isActive    Boolean      @default(true)
  
  // Relacionamentos
  newsletters Newsletter[]
  
  // Timestamps
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("newsletter_templates")
}

model Recipient {
  id           String     @id @default(uuid())
  newsletterId String
  clientId     String?
  tutorId      String?
  leadEmail    String?
  newsletter   Newsletter @relation(fields: [newsletterId], references: [id], onDelete: Cascade)
  client       Client?    @relation(fields: [clientId], references: [id], onDelete: SetNull)
  tutor        Tutor?     @relation(fields: [tutorId], references: [id], onDelete: SetNull)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  
  @@unique([newsletterId, clientId])
  @@unique([newsletterId, leadEmail])
  @@unique([newsletterId, tutorId])
}

model NewsletterLog {
  id           String     @id @default(uuid())
  newsletterId String
  sentAt       DateTime   @default(now())
  details      Json?
  newsletter   Newsletter @relation(fields: [newsletterId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  @@index([newsletterId])
  @@index([sentAt])
}

// Model para configurações de integrações
model IntegrationSettings {
  id              String   @id @default(uuid())
  userId          String   @unique
  
  // Configurações das integrações (armazenadas como JSON)
  whatsappConfig  String?  @db.Text
  openaiConfig    String?  @db.Text
  geminiConfig    String?  @db.Text
  deepseekConfig  String?  @db.Text
  emailConfig     String?  @db.Text
  
  // Relacionamento com usuário
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@map("integration_settings")
}

// ============================================
// AI Agents - Agentes, Templates e Automações
// ============================================

enum AIProvider {
  OPENAI
  GEMINI
  DEEPSEEK
}

enum AgentType {
  CHATBOT
  AUTOMATION
  ASSISTANT
  SCHEDULER
}

enum AgentStatus {
  ACTIVE
  PAUSED
  DRAFT
  ERROR
}

enum TemplateCategory {
  ATENDIMENTO
  VENDAS
  MARKETING
  SUPORTE
  AGENDAMENTO
  PERSONALIZADO
}

enum TemplateStatus {
  PUBLISHED
  DRAFT
  ARCHIVED
}

enum AutomationCategory {
  ATENDIMENTO
  MARKETING
  NOTIFICACAO
  INTEGRACAO
  AGENDAMENTO
}

enum AutomationTrigger {
  SCHEDULE
  WEBHOOK
  EVENT
  MANUAL
}

enum ExecutionStatus {
  SUCCESS
  FAILED
  PENDING
  RUNNING
}

// AI Agent - Agentes de IA configuráveis
model AIAgent {
  id              String        @id @default(uuid())
  userId          String
  name            String
  description     String?
  type            AgentType     @default(CHATBOT)
  status          AgentStatus   @default(DRAFT)
  provider        AIProvider    @default(OPENAI)
  model           String        @default("gpt-4o-mini")
  systemPrompt    String        @db.Text
  temperature     Float         @default(0.7)
  maxTokens       Int           @default(4096)
  templateId      String?
  
  // Métricas (desnormalizadas para performance)
  totalInteractions Int         @default(0)
  successRate       Float       @default(0)
  avgResponseTime   Float       @default(0)
  lastActiveAt      DateTime?
  
  // Voice settings (WhatsApp)
  voiceEnabled    Boolean       @default(false)
  voiceId         String        @default("nova")
  voiceSpeed      Float         @default(1.0)
  voiceModel      String        @default("tts-1")
  
  // Relacionamentos
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  template        AgentTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  executions      AgentExecution[]
  automations     Automation[]
  whatsappConversations WhatsAppConversation[]
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  @@index([userId, status])
  @@index([type])
  @@map("ai_agents")
}

// Template de Agente - Prompts reutilizáveis
model AgentTemplate {
  id            String           @id @default(uuid())
  userId        String
  name          String
  description   String?
  category      TemplateCategory @default(PERSONALIZADO)
  status        TemplateStatus   @default(DRAFT)
  content       String           @db.Text
  variables     String[]         @default([])
  provider      AIProvider?
  model         String?
  isDefault     Boolean          @default(false)
  usageCount    Int              @default(0)
  rating        Float?
  
  // Relacionamentos
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  agents        AIAgent[]
  
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  
  @@index([userId, category])
  @@index([status])
  @@map("agent_templates")
}

// Execução de Agente - Log de execuções
model AgentExecution {
  id          String          @id @default(uuid())
  agentId     String
  status      ExecutionStatus @default(PENDING)
  input       String?         @db.Text
  output      String?         @db.Text
  usage       Json?           // {prompt_tokens, completion_tokens, total_tokens}
  latencyMs   Int?
  error       String?         @db.Text
  metadata    Json?           // Dados extras (tutor, pet, etc.)
  
  // Relacionamentos
  agent       AIAgent         @relation(fields: [agentId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime        @default(now())
  
  @@index([agentId, createdAt])
  @@index([status])
  @@map("agent_executions")
}

// Automação - Fluxos automatizados
model Automation {
  id            String             @id @default(uuid())
  userId        String
  agentId       String?
  name          String
  description   String?
  category      AutomationCategory @default(ATENDIMENTO)
  status        AgentStatus        @default(DRAFT)
  trigger       AutomationTrigger  @default(MANUAL)
  triggerConfig Json?              // Configuração do trigger (cron, evento, etc.)
  
  // Métricas (desnormalizadas)
  executions    Int                @default(0)
  successRate   Float              @default(0)
  avgDuration   Float              @default(0)
  lastRunAt     DateTime?
  
  // Relacionamentos
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent         AIAgent?           @relation(fields: [agentId], references: [id], onDelete: SetNull)
  steps         AutomationStep[]
  logs          AutomationLog[]
  
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  
  @@index([userId, status])
  @@index([category])
  @@map("automations")
}

// Step de Automação - Passos do fluxo
model AutomationStep {
  id            String     @id @default(uuid())
  automationId  String
  type          String     // query, filter, message, email, delay, webhook, ai_chat
  name          String
  config        Json?      // Configuração específica do step
  position      Int
  
  // Relacionamentos
  automation    Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  
  @@unique([automationId, position])
  @@map("automation_steps")
}

// Log de Automação - Histórico de execuções
model AutomationLog {
  id            String          @id @default(uuid())
  automationId  String
  status        ExecutionStatus @default(PENDING)
  duration      Int?            // ms
  triggeredBy   String?         // manual, schedule, event, webhook
  stepsExecuted Int             @default(0)
  error         String?         @db.Text
  metadata      Json?           // Dados extras da execução
  
  // Relacionamentos
  automation    Automation      @relation(fields: [automationId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime        @default(now())
  
  @@index([automationId, createdAt])
  @@index([status])
  @@map("automation_logs")
}

// ============================================
// Documentos - Templates de documentos
// ============================================

enum DocumentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// Documentos Clínicos
enum ClinicalDocumentType {
  ANAMNESIS
  PRESCRIPTION
  DIAGNOSIS
  TUTOR_REPORT
  MEDICAL_CERTIFICATE
  EXAM_REQUEST
  SURGICAL_REPORT
  DISCHARGE_SUMMARY
  VACCINATION_CARD
  GENERAL
}

enum RecordingStatus {
  RECORDING
  PROCESSING
  TRANSCRIBED
  ANALYZED
  COMPLETED
  FAILED
}

model Document {
  id          String         @id @default(uuid())
  userId      String
  title       String
  content     String         @db.Text  // HTML do TipTap
  status      DocumentStatus @default(DRAFT)
  category    String?
  tags        String[]       @default([])
  
  // Relacionamentos
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  
  @@index([userId, status])
  @@index([category])
  @@map("documents")
}

// ============================================
// Documentos Clínicos - Gravação e Geração por IA
// ============================================

// Gravação de Consulta - Áudio e transcrição
model ConsultationRecording {
  id              String          @id @default(uuid())
  appointmentId   String          @unique
  userId          String
  audioUrl        String?
  audioFileName   String?
  audioDuration   Int?
  transcription   String?         @db.Text
  aiAnalysis      String?         @db.Text
  aiSummary       String?         @db.Text
  status          RecordingStatus @default(RECORDING)
  language        String          @default("pt-BR")
  errorMessage    String?

  appointment     Appointment     @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  clinicalDocuments ClinicalDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@map("consultation_recordings")
}

// Documento Clínico - Gerado por IA ou manualmente
model ClinicalDocument {
  id              String               @id @default(uuid())
  appointmentId   String
  petId           String
  tutorId         String
  userId          String
  recordingId     String?
  type            ClinicalDocumentType @default(GENERAL)
  title           String
  content         String               @db.Text
  htmlContent     String?              @db.Text
  pdfUrl          String?
  status          DocumentStatus       @default(DRAFT)
  isAiGenerated   Boolean              @default(false)
  aiModel         String?
  aiPromptUsed    String?              @db.Text

  sharedVia       String[]             @default([])
  sharedAt        DateTime?
  sharedTo        String?

  metadata        Json?
  version         Int                  @default(1)
  signedBy        String?
  crmv            String?

  appointment     Appointment          @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  pet             Pet                  @relation(fields: [petId], references: [id], onDelete: Cascade)
  tutor           Tutor                @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  recording       ConsultationRecording? @relation(fields: [recordingId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([appointmentId])
  @@index([petId])
  @@index([tutorId])
  @@index([userId])
  @@index([type])
  @@index([status])
  @@map("clinical_documents")
}

// ============================================
// WhatsApp Business API - Mensagens e Conversas
// ============================================

enum WhatsAppMessageType {
  TEXT
  IMAGE
  DOCUMENT
  AUDIO
  VIDEO
  LOCATION
  TEMPLATE
  INTERACTIVE
  BUTTON
  STICKER
  CONTACTS
}

enum WhatsAppMessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

enum WhatsAppMessageDirection {
  INBOUND
  OUTBOUND
}

enum WhatsAppConversationStatus {
  OPEN
  CLOSED
  PENDING
  ASSIGNED
}

enum WhatsAppCampaignStatus {
  DRAFT
  SCHEDULED
  RUNNING
  COMPLETED
  FAILED
  PAUSED
}

// WhatsApp Message - Mensagens individuais
model WhatsAppMessage {
  id             String                   @id @default(uuid())
  conversationId String
  waMessageId    String?                  @unique
  direction      WhatsAppMessageDirection @default(INBOUND)
  type           WhatsAppMessageType      @default(TEXT)
  status         WhatsAppMessageStatus    @default(PENDING)
  content        String                   @db.Text
  mediaUrl       String?
  mediaType      String?
  mediaCaption   String?
  metadata       Json?
  sentAt         DateTime?
  deliveredAt    DateTime?
  readAt         DateTime?
  failedReason   String?

  conversation WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([conversationId, createdAt])
  @@index([waMessageId])
  @@index([status])
  @@index([direction])
  @@map("whatsapp_messages")
}

// WhatsApp Conversation - Conversas com contatos
model WhatsAppConversation {
  id                 String                     @id @default(uuid())
  userId             String
  contactPhone       String
  contactName        String?
  contactPushName    String?
  status             WhatsAppConversationStatus @default(OPEN)
  assignedAgentId    String?
  tutorId            String?
  lastMessageAt      DateTime                   @default(now())
  lastMessagePreview String?
  unreadCount        Int                        @default(0)
  isAutoReplyEnabled Boolean                    @default(false)
  metadata           Json?

  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedAgent AIAgent?          @relation(fields: [assignedAgentId], references: [id], onDelete: SetNull)
  tutor         Tutor?            @relation(fields: [tutorId], references: [id], onDelete: SetNull)
  messages      WhatsAppMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, contactPhone])
  @@index([userId, status])
  @@index([userId, lastMessageAt])
  @@index([contactPhone])
  @@map("whatsapp_conversations")
}

// WhatsApp Campaign - Campanhas de envio em massa
model WhatsAppCampaign {
  id          String                 @id @default(uuid())
  userId      String
  name        String
  description String?
  status      WhatsAppCampaignStatus @default(DRAFT)

  templateName     String?
  templateLanguage String? @default("pt_BR")

  messageContent String              @db.Text
  messageType    WhatsAppMessageType @default(TEXT)
  mediaUrl       String?

  audienceType   String @default("all")
  audienceFilter Json?

  scheduledFor DateTime?
  startedAt    DateTime?
  completedAt  DateTime?

  totalRecipients Int @default(0)
  sentCount       Int @default(0)
  deliveredCount  Int @default(0)
  readCount       Int @default(0)
  failedCount     Int @default(0)

  user       User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipients WhatsAppCampaignRecipient[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([scheduledFor])
  @@index([status])
  @@map("whatsapp_campaigns")
}

// WhatsApp Campaign Recipient - Destinatários de campanha
model WhatsAppCampaignRecipient {
  id           String                @id @default(uuid())
  campaignId   String
  phone        String
  name         String?
  tutorId      String?
  status       WhatsAppMessageStatus @default(PENDING)
  waMessageId  String?
  sentAt       DateTime?
  deliveredAt  DateTime?
  readAt       DateTime?
  failedReason String?
  variables    Json?

  campaign WhatsAppCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([campaignId, phone])
  @@index([campaignId, status])
  @@index([phone])
  @@map("whatsapp_campaign_recipients")
}

// ============================================
// Notificações do Sistema
// ============================================

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
  ALERT
  WHATSAPP_MESSAGE
  APPOINTMENT_REMINDER
  AUTOMATION_COMPLETE
  CAMPAIGN_COMPLETE
}

enum NotificationChannel {
  IN_APP
  EMAIL
  WHATSAPP
  PUSH
}

model Notification {
  id       String              @id @default(uuid())
  userId   String
  type     NotificationType    @default(INFO)
  channel  NotificationChannel @default(IN_APP)
  title    String
  message  String              @db.Text
  link     String?
  metadata Json?
  isRead   Boolean             @default(false)
  readAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([type])
  @@map("notifications")
}
