# =====================================================
# Empório do Pet - Docker Compose Environment
# =====================================================
# Renomeie este arquivo para .env na raiz do projeto
# =====================================================

# ===== General =====
NODE_ENV=development

# ===== PostgreSQL =====
POSTGRES_USER=emporio
POSTGRES_PASSWORD=emporio_dev
POSTGRES_DB=emporio_db
POSTGRES_PORT=5433

# ===== Redis =====
REDIS_PASSWORD=
REDIS_PORT=6380

# ===== Backend =====
BACKEND_PORT=3001
JWT_SECRET=your-super-secret-jwt-key-change-in-production
NEXTAUTH_SECRET=your-nextauth-secret-change-in-production

# ===== Frontend URL =====
FRONTEND_URL=http://localhost:3000

# ===== Admin Tools (Dev) =====
ADMINER_PORT=8080
REDIS_COMMANDER_PORT=8081

