# =====================================================
# Empório do Pet AI Service - Environment Variables
# =====================================================
# Copie este arquivo para .env e configure os valores
# =====================================================

# Application
ENVIRONMENT=development
LOG_LEVEL=DEBUG
HOST=127.0.0.1
PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8000

# CORS - Comma-separated list of allowed origins
# =====================================================
# API Keys (Opcional para DEV)
# =====================================================
# Nota: Em produção, as API keys são passadas por request
# pelo backend NestJS que as obtém do IntegrationSettings.
# 
# Para testes locais SEM o backend, descomente e configure:
# =====================================================

# OpenAI API Key (para testes diretos no AI Service)
# OPENAI_API_KEY=sk-...

# Google Gemini API Key (alternativa)
# GEMINI_API_KEY=...

# DeepSeek API Key (alternativa)
# DEEPSEEK_API_KEY=...

# =====================================================
# Cache Settings
# =====================================================
# Tempo de cache para respostas (em segundos)
RESPONSE_CACHE_TTL=3600

# =====================================================
# Rate Limiting
# =====================================================
# Máximo de requests por minuto por cliente
RATE_LIMIT_PER_MINUTE=60

# =====================================================
# Model Defaults
# =====================================================
# Modelo padrão para chat
DEFAULT_CHAT_MODEL=gpt-4o-mini

# Modelo padrão para TTS
DEFAULT_TTS_MODEL=tts-1

# Voz padrão para TTS
DEFAULT_TTS_VOICE=alloy

# Modelo padrão para STT/Transcription
DEFAULT_STT_MODEL=whisper-1

# =====================================================
# RAG - Retrieval-Augmented Generation
# =====================================================
# URL de conexão com o PostgreSQL (DEVE ser o mesmo banco do Prisma/backend)
# IMPORTANTE: Certifique-se de que a porta e credenciais coincidam com o DATABASE_URL do backend
# NÃO inclua ?schema=public (parâmetro exclusivo do Prisma, não compatível com asyncpg)
DATABASE_URL=postgresql://emporio:emporio_2024@localhost:15432/emporio_db

# Modelo de embedding OpenAI
EMBEDDING_MODEL=text-embedding-3-small

# Dimensões do vetor de embedding (deve coincidir com o vector(N) no banco)
EMBEDDING_DIMENSIONS=1536

# Número padrão de chunks retornados por consulta RAG
DEFAULT_RAG_TOP_K=5

# Threshold mínimo de similaridade (cosine) para retornar chunks
DEFAULT_RAG_THRESHOLD=0.7

# Tamanho máximo de cada chunk em tokens
CHUNK_SIZE=600

# Overlap entre chunks consecutivos em tokens
CHUNK_OVERLAP=100

# =====================================================
# Timeouts
# =====================================================
# Timeout para chamadas à API de LLM (segundos)
LLM_TIMEOUT=60

# Timeout para TTS (segundos)
TTS_TIMEOUT=30

# Timeout para STT/Transcription (segundos)
STT_TIMEOUT=60
